# Copie para .env e ajuste conforme necessário
POSTGRES_USER=weblicitacoes
POSTGRES_PASSWORD=weblicitacoes_secret
POSTGRES_DB=weblicitacoes
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg2://weblicitacoes:weblicitacoes_secret@db:5432/weblicitacoes

API_PORT=8000
FRONTEND_PORT=3000

# false = navegador real via xvfb no Docker (recomendado); true = headless
SCRAPER_HEADLESS=false
SCRAPER_DELAY_SEC=2.0
SCRAPER_POLL_INTERVAL_SEC=10
SCRAPER_FORM_TIMEOUT_MS=60000
SCRAPER_MAX_RETRIES=3

# Para migrar o banco para nuvem depois, basta alterar DATABASE_URL
# DATABASE_URL=postgresql+psycopg2://user:pass@cloud-host:5432/weblicitacoes
