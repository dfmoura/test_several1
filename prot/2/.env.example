# B3 API - Eventos Provisionados
# Obtenha client_id e client_secret no portal B3 (contrato/credenciais).

# Ambiente: cert (certificação) ou prod (produção)
B3_ENV=cert

# OAuth2 - Client Credentials (B3 entrega no pacote de acesso)
B3_CLIENT_ID=seu_client_id
B3_CLIENT_SECRET=seu_client_secret

# Escopo do token (conforme documentação B3 para a API de Eventos Provisionados)
# Exemplo típico (ajuste conforme orientação B3):
B3_SCOPE=https://apib3i-cert.b3.com.br/.default

# URLs (só altere se a B3 indicar outro)
# Certificação: https://apib3i-cert.b3.com.br:2443
# Produção: https://investidor.b3.com.br:2443
