##ID_1289## tempo: 128 (ms)
/* Runtime-info
Application: OperacaoProducao
Referer: https://satis2.nuvemdatacom.com.br:8110/mgeprod/OperacaoProducao.xhtml5
ResourceID: br.com.sankhya.producao.cad.OperacaoProducao
service-name: OperacaoProducaoSP.confirmarApontamento
uri: /mgeprod/service.sbr
*/
SELECT
  SUM(VLRTOT + VLRIPI - VLRDESC - ITE.VLRREPRED) as SOMA,
  SUM(CASE WHEN NVL(ITE.CODTRIB, 0) = 20 AND NVL(ITE.CODMOTDESONERAICMS, 0) = 3 AND USOPROD<>'D' THEN ITE.VLRREPRED ELSE 0 END) as DESON_NAO_SUBTRAIDA_VLRNOTA,
  SUM(CASE WHEN NVL(ITE.CODTRIB, 0) = 61 THEN 0 ELSE ITE.BASESUBSTIT END) as SOMABASESUBSTIT,
  SUM(BASESUBSTSEMRED) as SOMABASESUBSTITSEMRED,
  SUM(CASE WHEN NVL(ITE.CODTRIB, 0) = 61 THEN 0 ELSE ITE.VLRSUBST END) as SOMAVLRSUBST,
  SUM(CASE WHEN USOPROD='D' THEN 0 ELSE VLRDESC END) as SOMADESCONTO,
  SUM(BASEIPI) as SOMABASEIPI,
  SUM(VLRIPI) as SOMAVLRIPI,
  SUM(BASEIPI * NVL(ALIQIPI, 0) / 100) as SOMAVLRIPI_CALC,
  SUM(PERCREDVLRIPI) as SOMAPERCREDVLRIPI,
  SUM(BASEICMS) as SOMABASEICMS,
  SUM(VLRICMS) as SOMAVLRICMS,
  SUM(VLRSTEXTRANOTA) as SOMAVLRSTEXTRANOTA,
  SUM((CASE WHEN VLRCUS=0 THEN VLRTOT ELSE VLRCUS * QTDNEG END) + VLRIPI) as SOMAPRECO,
  SUM(VLRTOT) as SOMAVLRTOT,
  SUM(CASE WHEN VLRSUBST > 0 THEN VLRTOT ELSE 0 END) as SOMAVLRTOTTEMST,
  SUM(CASE WHEN VLRIPI > 0 THEN VLRTOT ELSE 0 END) as SOMAVLRTOTTEMIPI,
  SUM(CASE WHEN VLRIPI > 0 AND VLRSUBST > 0 THEN VLRTOT ELSE 0 END) as SOMAVLRTOTTEMIPIST,
  SUM(CASE WHEN VLRICMS > 0 THEN VLRTOT * (ALIQICMS / 100.00) ELSE 0 END) as SOMAVICMSCALCSEMIPI,
  SUM(CASE WHEN VLRICMS > 0 AND VLRSUBST > 0 THEN VLRTOT * (ALIQICMS / 100.00) ELSE 0 END) as SOMAVICMSCALCSEMIPITEMST,
  SUM(CASE WHEN VLRICMS > 0 THEN (VLRTOT + (VLRTOT * ALIQIPI / 100.00)) * (ALIQICMS / 100.00) ELSE 0 END) as SOMAVICMSCALCCOMIPI,
  SUM(CASE WHEN VLRICMS > 0 AND VLRSUBST > 0 THEN (VLRTOT + (VLRTOT * ALIQIPI / 100.00)) * (ALIQICMS / 100.00) ELSE 0 END) as SOMAVICMSCALCCOMIPITEMST,
  SUM((CASE WHEN USOPROD='D' THEN VLRTOT  + VLRIPI - VLRDESC - ITE.VLRREPRED ELSE 0 END)) as SOMAMP,
  SUM((CASE WHEN USOPROD='D' THEN VLRTOT - VLRDESC - ITE.VLRREPRED ELSE 0 END)) as SOMAMPSEMIPI,
  SUM(CASE WHEN USOPROD='D' THEN 0 ELSE ITE.VLRREPRED END) as SOMADESCONTORED,
  SUM(CASE WHEN USOPROD='D' THEN 0 ELSE ITE.VLRREPREDSEMDESC END) as SOMAREPASSEICMSSEMDESC,
  SUM(CASE WHEN VLRSUBST > 0 THEN VLRDESC ELSE 0 END ) AS SOMADESCONTOCOMST,
  SUM(CASE WHEN USOPROD='D' AND VLRSUBST > 0 THEN VLRDESC ELSE 0 END ) AS SOMADESCONTOCOMSTMP,
  SUM(CASE WHEN VLRSUBST = 0 THEN BASEICMS + VLRIPI ELSE 0 END) as SOMASEMST,
  SUM(CASE WHEN VLRSUBST = 0 THEN VLRICMS ELSE 0 END) as SOMAICMSSEMST,
  SUM(CASE WHEN USOPROD='S' THEN CUSTO * QTDNEG ELSE 0 END) as SOMACUSTOSERV,
  SUM(CASE WHEN USOPROD<>'S' AND USOPROD<>'D' THEN CUSTO * QTDNEG ELSE 0 END) as SOMACUSTOPROD,
  SUM(CASE WHEN USOPROD='S' THEN VLRTOT + VLRIPI - VLRDESC - ITE.VLRREPRED ELSE 0 END) as SOMASERVICO,
  MIN(CODCFO) AS MINCODCFO,
  MAX(CODCFO) AS MAXCODCFO,
  SUM(CASE WHEN USOPROD='D' THEN BASESUBSTIT ELSE 0 END ) as SOMABASESUBSTITMP,
  SUM(CASE WHEN USOPROD='D' THEN VLRSUBST ELSE 0 END ) as SOMAVLRSUBSTMP,
  SUM(CASE WHEN BASESUBSTIT > 0 THEN VLRTOT + VLRIPI - VLRDESC - ITE.VLRREPRED ELSE 0 END) AS SOMACOMBASEST,
  SUM(CASE WHEN BASESUBSTIT > 0 THEN VLRTOT - VLRDESC - ITE.VLRREPRED ELSE 0 END) AS SOMACOMBASESTSEMIPI,
  SUM(CASE WHEN VLRSUBST = 0 THEN BASEICMS ELSE 0 END ) as SOMABASEICMSSEMST,
  SUM(CASE WHEN VLRSUBST = 0 THEN VLRTOT - VLRDESC - ITE.VLRREPRED ELSE 0 END ) as SOMASEMSTSEMIPI,
  SUM(CASE WHEN VLRSUBST > 0 THEN BASEICMS ELSE 0 END ) as SOMABASEICMSCOMST,
  SUM(CASE WHEN VLRSUBST > 0 THEN VLRIPI ELSE 0 END ) as SOMAVLRIPICOMST,
  SUM(CASE WHEN VLRSUBST > 0 THEN VLRICMS ELSE 0 END ) AS SOMAVLRICMSCOMST,
  SUM(CASE WHEN USOPROD='D' THEN 0 ELSE VLRTOT - VLRDESC - ITE.VLRREPRED END) AS SOMASEMIPI,
  MAX(NVL(ALQICMSMAX.ALIQUOTA, 0)) as MAX_ALIQICMS,
  MIN(NVL(ALQICMSMIN.ALIQUOTA, 0)) as MIN_ALIQICMS,
  MAX(NVL(ALQICMSMAX.ALIQUOTANORMAL, 0)) as MAX_ALIQICMSNORMAL,
  MIN(NVL(ALQICMSMIN.ALIQUOTANORMAL, 0)) as MIN_ALIQICMSNORMAL,
  SUM(CASE WHEN CODTRIB = 51 THEN 1 ELSE 0 END) AS ITENSDIFERIMENTO, --Itens com diferimento de ICMS, cuja BASEICMS * ALIQ <> VALORICMS.
  SUM(NVL(CASE WHEN (CODTRIB = 51 AND CODCFO LIKE '3%') THEN VLRICMSDIFERIDO ELSE 0 END, 0)) AS VLRICMSDIF_NAC, --VLRICMSDIFERIDO_NACIONALIZACAO : Itens com diferimento de ICMS EXCLUSIVO na importaçăo (nacionalizaçăo) 1386419
  SUM(CASE WHEN USOPROD='D' OR (CODTRIB = 40 AND CODMOTDESONERAICMS > 0) THEN 0 ELSE ITE.VLRREPRED END) AS SOMADESCRED_ITENSNAOISENTOS,
  

  SUM(CASE WHEN USOPROD='D'  AND KIT.SOMAICMSCOMPKIT = 'S'  THEN BASEICMS ELSE 0 END ) as SOMABASEICMSMP,
  SUM(CASE WHEN USOPROD='D'  AND KIT.SOMAICMSCOMPKIT = 'S'  THEN VLRICMS ELSE 0 END ) as SOMAVLRICMSMP,
  SUM(CASE WHEN USOPROD='D' AND BASESUBSTIT > 0  AND KIT.SOMAICMSCOMPKIT = 'S'  THEN VLRTOT + VLRIPI - VLRDESC - ITE.VLRREPRED ELSE 0 END ) AS SOMACOMBASESTMP,
  SUM(CASE WHEN USOPROD='D' AND BASESUBSTIT > 0  AND KIT.SOMAICMSCOMPKIT = 'S'  THEN VLRTOT - VLRDESC - ITE.VLRREPRED ELSE 0 END ) AS SOMACOMBASESTMPSEMIPI,
  SUM(CASE WHEN USOPROD='D' AND VLRSUBST > 0  AND KIT.SOMAICMSCOMPKIT = 'S'  THEN VLRIPI ELSE 0 END ) AS SOMAVLRIPICOMSTMP,
  SUM(CASE WHEN USOPROD='D' AND VLRSUBST > 0  AND KIT.SOMAICMSCOMPKIT = 'S'  THEN VLRICMS ELSE 0 END ) AS SOMAVLRICMSCOMSTMP,
  SUM(CASE WHEN USOPROD='D' AND VLRSUBST > 0  AND KIT.SOMAICMSCOMPKIT = 'S'  THEN ITE.VLRREPRED ELSE 0 END ) AS SOMADESCONTOREDMP
FROM TGFITE ITE
      LEFT JOIN (SELECT KIT.SOMAICMSCOMPKIT, I.NUNOTA, I.SEQUENCIA 
                  FROM TSIKIT KIT
                       INNER JOIN TGFPRO PRO ON PRO.CODCONFKIT = KIT.CODCONFKIT
                       INNER JOIN TGFITE I ON I.CODPROD = PRO.CODPROD
                       INNER JOIN TGFVAR VAR ON VAR.NUNOTAORIG = I.NUNOTA AND VAR.SEQUENCIAORIG = I.SEQUENCIA
                 WHERE VAR.NUNOTA <> VAR.NUNOTAORIG
                 GROUP BY KIT.SOMAICMSCOMPKIT, I.NUNOTA, I.SEQUENCIA
                  ) KIT ON KIT.NUNOTA = ITE.NUNOTA AND KIT.SEQUENCIA = ITE.SEQUENCIA 
      LEFT JOIN (
			SELECT NUNOTA, MIN(ALQICMSMIN.ALIQUOTA)  AS ALIQUOTA, MIN(NVL(ALQICMSMIN.ALIQUOTANORMAL, 0)) AS ALIQUOTANORMAL
			  FROM TGFDIN ALQICMSMIN
			 WHERE ALQICMSMIN.CODIMP = 1
			   AND ALQICMSMIN.CODINC = 1 
			 GROUP BY NUNOTA
      ) ALQICMSMIN ON (ALQICMSMIN.NUNOTA = ITE.NUNOTA)
      LEFT JOIN (
            SELECT NUNOTA, MAX(ALQICMSMAX.ALIQUOTA)  AS ALIQUOTA, MAX(NVL(ALQICMSMAX.ALIQUOTANORMAL, 0)) AS ALIQUOTANORMAL
              FROM TGFDIN ALQICMSMAX
             WHERE ALQICMSMAX.CODIMP = 1
               AND ALQICMSMAX.CODINC = 1 
             GROUP BY NUNOTA
      ) ALQICMSMAX ON ALQICMSMAX.NUNOTA = ITE.NUNOTA
      
WHERE ITE.NUNOTA = ?
  AND ITE.SEQUENCIA > 0
