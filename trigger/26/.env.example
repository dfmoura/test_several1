APP_ENV=local
APP_SECRET=change-me-local-dev-secret-32chars
APP_PORT=3001

# Docker Compose (serviço db). Em host local use localhost:5433
DATABASE_URL=postgres://reta:reta@db:5432/reta
REDIS_URL=redis://redis:6379/0

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=reta
S3_REGION=us-east-1

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=gestao@retaetiquetas.local

BILLING_PROVIDER=fake
NFE_PROVIDER=fake
CNPJ_PROVIDER=brasilapi
CEP_PROVIDER=viacep

NEXT_PUBLIC_API_URL=http://localhost/api

