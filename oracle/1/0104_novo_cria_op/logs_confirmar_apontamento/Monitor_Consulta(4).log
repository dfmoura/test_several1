service-name: OperacaoProducaoSP.confirmarApontamento
uri: /mgeprod/service.sbr
*/
SELECT
    IATV.IDIATV,
	IATV.IDEFX,
	IATV.DHINCLUSAO,
    IATV.DHINICIO,
    IATV.DHFINAL,
    EFX.DESCRICAO,
    ATV.IDRPAOPER,
	APA.NUAPO,
    APO.DHAPO,
    APA.SEQAPA,
    APA.CODPRODPA,
	APA.CONTROLEPA,    
	APA.QTDAPONTADA,
	APA.QTDPERDA,
	APA.QTDFAT,    
    EIATV.IDEIATV AS ID_EXEC,
    EIATV.TIPO AS TIPO_EXEC,
    EIATV.DHINICIO AS DHINICIO_EXEC,
    EIATV.DHFINAL AS DHFINAL_EXEC
FROM TPRIATV IATV
INNER JOIN TPREFX EFX ON (IATV.IDEFX = EFX.IDEFX)
INNER JOIN TPRATV ATV ON (ATV.IDEFX = EFX.IDEFX)
LEFT JOIN TPRAPO APO ON(IATV.IDIATV = APO.IDIATV)
LEFT JOIN TPRAPA APA ON(APA.NUAPO = APO.NUAPO)
LEFT JOIN TPREIATV EIATV ON (IATV.IDIATV = EIATV.IDIATV)
WHERE
IATV.IDIPROC = ?
AND EFX.TIPO NOT IN (1111)
AND (APA.CODPRODPA IS NULL OR APA.CODPRODPA = ?) 
AND (APA.CONTROLEPA IS NULL OR APA.CONTROLEPA = ?) 
ORDER BY IATV.IDIATV
