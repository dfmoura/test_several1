SELECT *
FROM
	(SELECT
		COUNT (1) AS QTDTPP
	FROM
		TPRTPP
	WHERE
		IDPROC = ?
		AND CODPRODPA = ?
		AND (NVL(CONTROLEPA, ' ') = ' ' OR CONTROLEPA = ?)
        AND (? = 0 OR CODPRODTAR = ?)) TPP,
	(SELECT
		COUNT(1) AS QTDTCA
	FROM
		TPRTCA
	WHERE
		IDPROC = ?
		AND CODPRODPA = ?
		AND (NVL(CONTROLEPA, ' ') = ' ' OR CONTROLEPA = ?)
        AND (? = 0 OR CODPRODTAR = ?)) TCA
