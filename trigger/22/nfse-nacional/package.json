{
  "name": "nfse-nacional",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema NFS-e Nacional — Emissor Integrado",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "node scripts/migrate.js",
    "docker:up": "docker compose --profile dev up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "pg": "^8.13.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
