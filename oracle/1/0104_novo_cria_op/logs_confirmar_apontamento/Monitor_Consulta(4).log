 SELECT SUM(ITE.QTDNEG - NVL(PERDA.QTDPERDA, 0)) AS QTDNEG  FROM TGFCAB CAB  INNER JOIN TGFITE ITE ON CAB.NUNOTA = ITE.NUNOTA  LEFT JOIN TPRITE_PERDA PERDA ON CAB.NUNOTA = PERDA.NUNOTA AND ITE.SEQUENCIA = PERDA.SEQUENCIA  LEFT JOIN TPRIATV IATV ON IATV.IDIPROC = CAB.IDIPROC  LEFT JOIN TPRAPO APO ON APO.IDIATV = IATV.IDIATV  LEFT JOIN TPRAPA APA ON APA.NUAPO = APO.NUAPO  WHERE CAB.IDIPROC = ?  AND TIPMOV = 'F'  AND (ITE.CODPROD = ? OR (ITE.CODPROD = APA.CODPRODPA AND ITE.USOPROD = 'V')) AND ITE.USOPROD IN ('M','2')  AND APA.CONTROLEPA = ?  AND APO.NUAPO = ?  AND CAB.NUNOTA IN (SELECT ITE.NUNOTA FROM TGFITE ITE WHERE (ITE.CODPROD = ? OR (CODPROD = APA.CODPRODPA AND ITE.USOPROD = 'V')) AND (CONTROLE = APA.CONTROLEPA  OR CONTROLE = ?) )  AND CAB.NUNOTA NOT IN (SELECT ITESP.NUNOTA FROM TPRLSP LSP, TPRIATV IATVSP, TGFCAB CABSP, TGFITE ITESP WHERE LSP.IDEFX = IATVSP.IDEFX AND IATVSP.IDIPROC = CABSP.IDIPROC AND ITESP.NUNOTA = CABSP.NUNOTA AND ITESP.CODPROD = LSP.CODPRODSP AND CABSP.IDIPROC = CAB.IDIPROC)
