SELECT TPRLMP.AD_SEQIMP AS AD_SEQIMP,TPRLMP.CODLOCALBAIXA AS CODLOCALBAIXA,TPRLMP.CODLOCALORIG AS CODLOCALORIG,TPRLMP.CODPRODMP AS CODPRODMP,TPRLMP.CODPRODPA AS CODPRODPA,TPRLMP.CODUSUALT AS CODUSUALT,TPRLMP.CODUSUCAD AS CODUSUCAD,TPRLMP.CODVOL AS CODVOL,TPRLMP.CONSUREFUGO AS CONSUREFUGO,TPRLMP.CONTROLEMP AS CONTROLEMP,TPRLMP.CONTROLEPA AS CONTROLEPA,TPRLMP.DHALTER AS DHALTER,TPRLMP.DHCAD AS DHCAD,TPRLMP.ESTOQUETERCEIRO AS ESTOQUETERCEIRO,TPRLMP.FIXAQTDAPO AS FIXAQTDAPO,TPRLMP.GERAREQUISICAO AS GERAREQUISICAO,TPRLMP.IDEFX AS IDEFX,TPRLMP.LIBERADESVIO AS LIBERADESVIO,TPRLMP.PERCDESVIOINF AS PERCDESVIOINF,TPRLMP.PERCDESVIOSUP AS PERCDESVIOSUP,TPRLMP.PROPMPFIXA AS PROPMPFIXA,TPRLMP.QTDMISTURA AS QTDMISTURA,TPRLMP.SEQMP AS SEQMP,TPRLMP.TIPOCONTROLEMP AS TIPOCONTROLEMP,TPRLMP.TIPOQTD AS TIPOQTD,TPRLMP.TIPOUSOMP AS TIPOUSOMP,TPRLMP.VERIFICAEST AS VERIFICAEST,TPRLMP.VINCULOSERIEPA AS VINCULOSERIEPA, (
SELECT 
    CUS.CUSSEMICM * LMP.QTDMISTURA
FROM 
    TPRLMP LMP,
    TGFCUS CUS
WHERE 
    LMP.CODPRODPA = TPRLMP.CODPRODPA
    AND LMP.IDEFX= TPRLMP.IDEFX
    AND LMP.CODPRODMP = TPRLMP.CODPRODMP 
    AND LMP.CODPRODMP = CUS.CODPROD AND CUS.DTATUAL= (SELECT MAX(DTATUAL) FROM TGFCUS CUS2 WHERE CUS.CODPROD = CUS2.CODPROD)) AS AD_CUSMEDSEMICM_TOT, (
SELECT 
    CUS.CUSSEMICM
FROM 
    TPRLMP LMP,
    TGFCUS CUS
WHERE 
    LMP.CODPRODPA = TPRLMP.CODPRODPA
    AND LMP.IDEFX= TPRLMP.IDEFX
    AND LMP.CODPRODMP = TPRLMP.CODPRODMP 
    AND LMP.CODPRODMP = CUS.CODPROD AND CUS.DTATUAL= (SELECT MAX(DTATUAL) FROM TGFCUS CUS2 WHERE CUS.CODPROD = CUS2.CODPROD)) AS AD_CUSMEDSEMICM_UNT, (  
(QTDMISTURA / (select nvl(AD_DENSIDADE,1) from tgfpro where codprod = TPRLMP.codprodpa))*100) AS AD_PART_QTDMISTURAMP, ( SELECT REFERENCIA FROM TGFPRO PRO WHERE CODPROD = TPRLMP.CODPRODMP) AS REFERENCIA FROM TPRLMP /*SQL_92_JOINED_TABLES*/   WHERE (TPRLMP.CODPRODMP = ?)  AND ROWNUM <= 2
