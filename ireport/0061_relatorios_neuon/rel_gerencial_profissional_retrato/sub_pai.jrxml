<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="sub_pai" language="groovy" pageWidth="515" pageHeight="802" orientation="Portrait" columnWidth="515" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
    <parameter name="P_NUATV" class="java.math.BigDecimal"/>

    <queryString>
        <![CDATA[
SELECT
    CAST(2 AS NUMBER) AS NUATV_FILHO,
    CAST(1 AS NUMBER) AS NUATV_PAI,
    '1 - Impressao da Capa do Backlog Requisitos' AS TITULO_PAI
FROM DUAL
UNION ALL
SELECT
    CAST(3 AS NUMBER) AS NUATV_FILHO,
    CAST(1 AS NUMBER) AS NUATV_PAI,
    '1 - Impressao da Capa do Backlog Requisitos' AS TITULO_PAI
FROM DUAL
        ]]>
    </queryString>

    <field name="NUATV_FILHO" class="java.math.BigDecimal"/>
    <field name="NUATV_PAI" class="java.math.BigDecimal"/>
    <field name="TITULO_PAI" class="java.lang.String"/>
    <filterExpression><![CDATA[$P{P_NUATV} != null && $F{NUATV_FILHO}.compareTo($P{P_NUATV}) == 0]]></filterExpression>

    <columnHeader>
        <band height="20">
            <staticText>
                <reportElement x="0" y="2" width="110" height="16"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[ID Atividade Pai]]></text>
            </staticText>
            <staticText>
                <reportElement x="110" y="2" width="405" height="16"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Título Pai]]></text>
            </staticText>
            <line><reportElement x="0" y="19" width="515" height="1"/></line>
        </band>
    </columnHeader>

    <detail>
        <band height="18">
            <textField>
                <reportElement x="0" y="2" width="110" height="14"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{NUATV_PAI}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="110" y="2" width="405" height="14"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression class="java.lang.String"><![CDATA[$F{TITULO_PAI}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
</jasperReport>
