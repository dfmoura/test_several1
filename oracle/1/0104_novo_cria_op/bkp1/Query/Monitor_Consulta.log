uri: /mge/service.sbr
*/
 SELECT 
X.*
FROM( 
	SELECT
	    /*$sqlserver$ TOP 1 $sqlserver$*/
		 RPA.DESCRICAO,
		 MER.QTD
	FROM 
		 TPRMER MER
		 INNER JOIN TPRRPA RPA ON(RPA.IDRPA = MER.IDRPA)
	WHERE MER.IDIPROC = 1
	GROUP BY MER.IDRPA, MER.DHMOV, MER.QTD, RPA.DESCRICAO
	ORDER BY MER.DHMOV DESC

) X
WHERE ROWNUM < 2

