<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="analitico_cob" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.948717100000073"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="ireport.definition"/>
	<parameter name="PDIR_MODELO" class="java.lang.String" isForPrompting="false"/>
	<parameter name="PK_NUNOTAORIG" class="java.math.BigDecimal" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
CAB.CODPARC
,PAR.NOMEPARC AS UNIDADE
,PAR.RAZAOSOCIAL AS CLIENTE
,PAR.IDENTINSCESTAD AS IE
,ITE.AD_DATA
,CAB.NUNOTA
,ITE.CODPROD
,AD_IDPROCAFE|| ' - ' ||PRO.DESCRPROD AS DESCRPROD
,CASE WHEN ITE.AD_DIAS = 0 THEN NULL ELSE ITE.AD_DIAS END AS AD_DIAS
,ITE.QTDNEG /60 AS SACAS_BKP
,TO_CHAR(ROUND((ITE.VLRUNIT* 60) / CASE WHEN NVL(ITE.AD_DIAS,1) = 0 THEN 1 END,9),'FM9999999990.000000000') AS VLRUNIT_BKP
,ITE.QTDNEG AS SACAS
,TO_CHAR(ROUND((ITE.VLRUNIT) ,9),'FM9999999990.000000000') AS VLRUNIT
,ITE.VLRTOT
,CAB.AD_PERIODOFECHINI||'  até: '||CAB.AD_PERIODOFECHFIN AS PER_REF
,CASE WHEN PAR.AD_COOPERADO = 1 THEN 'COOPERADO'
      ELSE 'NAÕ COOPERADO'
      END AS TIPO_CLIENTE
,TOP.AD_TIPOSERV
,ITE.OBSERVACAO
,CASE WHEN ITE.USOPROD <> 'S' THEN ITE.VLRTOT
      ELSE 0 END AS VLR_TT_PROD
,CASE WHEN ITE.USOPROD <> 'S' THEN  ROUND(ITE.VLRUNIT / 60, 8)
     ELSE 0 END AS VLR_UNIT_PROD

FROM TGFCAB CAB
LEFT JOIN TGFITE ITE ON CAB.NUNOTA = ITE.NUNOTA
LEFT JOIN TGFPAR PAR ON CAB.CODPARC = PAR.CODPARC
LEFT JOIN TGFTOP TOP ON CAB.CODTIPOPER = TOP.CODTIPOPER AND TOP.DHALTER = (SELECT MAX(DHALTER) FROM TGFTOP WHERE CODTIPOPER = TOP.CODTIPOPER)
LEFT JOIN TGFPRO PRO ON ITE.CODPROD = PRO.CODPROD
WHERE ((CAB.NUNOTA = $P{PK_NUNOTAORIG} AND CAB.TIPMOV = 'P') OR (CAB.NUNOTA IN (SELECT NUNOTAORIG FROM TGFVAR WHERE NUNOTA = $P{PK_NUNOTAORIG}) AND CAB.TIPMOV = 'P'))

ORDER BY ITE.AD_DATA,PRO.AD_IDPROCAFE]]>
	</queryString>
