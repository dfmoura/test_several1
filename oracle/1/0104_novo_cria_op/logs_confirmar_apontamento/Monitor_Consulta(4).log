 SELECT IPA.CODPRODPA 		, IPA.CONTROLEPA 	   	, ROUND( SUM (APA.QTDAPONTADA) + SUM(APA_PERDA.QTDPERDA) - SUM (IPA.QTDPRODUZIR), PROD.DECQTD)  AS TOTAL_APONTADO  	FROM TPRIPA IPA, TGFPRO PROD, 		 (SELECT APA.CODPRODPA, APA.CONTROLEPA,SUM(APA.QTDAPONTADA) AS QTDAPONTADA  		  	FROM TPRAPA APA   		  WHERE EXISTS ( SELECT APO.NUAPO 					   	 	FROM TPRAPO APO 					   	 	INNER JOIN TPRIATV IATV ON (IATV.IDIATV = APO.IDIATV) 					   	 WHERE APO.NUAPO   = APA.NUAPO 							AND IATV.IDEFX = ? AND IATV.IDIPROC = ?					   ) 		     GROUP BY APA.CODPRODPA, APA.CONTROLEPA 		 ) APA, 		 (SELECT APA.CODPRODPA, APA.CONTROLEPA,SUM(APA.QTDPERDA) AS QTDPERDA 		 	FROM TPRAPA APA 		 	INNER JOIN TPRAPO APO ON (APO.NUAPO = APA.NUAPO) 		 WHERE EXISTS (SELECT 1  		 	FROM TPRIATV IATV  				WHERE IATV.IDIPROC = ?  		 			AND APO.IDIATV = IATV.IDIATV  		 		)  		  GROUP BY APA.CODPRODPA, APA.CONTROLEPA  		 ) APA_PERDA  WHERE PROD.CODPROD = IPA.CODPRODPA AND IPA.IDIPROC   = ?  AND IPA.CONCLUIDO = 'N'  AND APA.CODPRODPA = IPA.CODPRODPA  AND APA.CONTROLEPA = IPA.CONTROLEPA  AND APA_PERDA.CODPRODPA = IPA.CODPRODPA  AND APA_PERDA.CONTROLEPA = IPA.CONTROLEPA 	AND EXISTS ( SELECT 1 			   	 	FROM TPRAPA APA INNER JOIN TPRAPO APO ON(APO.NUAPO = APA.NUAPO) 			   	 WHERE APA.CONTROLEPA = IPA.CONTROLEPA 					AND APA.CODPRODPA = IPA.CODPRODPA 			   )	GROUP BY IPA.CODPRODPA, IPA.CONTROLEPA, PROD.DECQTD 	HAVING SUM (APA.QTDAPONTADA) + SUM(APA_PERDA.QTDPERDA) - SUM (IPA.QTDPRODUZIR) < 0 
