service-name: PesquisaSP.getSuggestion
uri: /mge/service.sbr
*/
SELECT
 OPC.NUCAMPO,
 NULL AS NOMECAMPO,
 NULL AS DESCRCAMPO,
 NULL AS LABEL,
 NULL AS ADICIONAL,
 VALOR AS CHAVE,
 OPCAO AS VALOR,
 OPC.ORDEM,
 'O' AS TIPO,
 NULL AS CALCULADO,
 NULL AS PERMITEPADRAO,
 NULL AS APRESENTACAO,
 NULL AS PERMITEPESQUISA,
 NULL AS TIPCAMPO,
 NULL AS VISIVELGRIDPESQUISA
FROM
 TDDOPC OPC
WHERE
 EXISTS(
     SELECT 1 FROM TDDCAM CAM WHERE CAM.NUCAMPO = OPC.NUCAMPO AND CAM.NOMETAB = ?  
 )
UNION ALL
SELECT
 PCO.NUCAMPO,
 NULL AS NOMECAMPO,
 NULL AS DESCRCAMPO,
 CASE
    WHEN NOME = 'labelParam' THEN
	   GET_TSIPAR_TIPO_CT(VALOR)
 END AS LABEL,
 NULL AS ADICIONAL,
 NOME AS CHAVE,
  VALOR, 
 
 NULL AS ORDEM,
 'P' AS TIPO,
 NULL AS CALCULADO,
 NULL AS PERMITEPADRAO,
 NULL AS APRESENTACAO,
 NULL AS PERMITEPESQUISA,
 NULL AS TIPCAMPO,
 NULL AS VISIVELGRIDPESQUISA
FROM
 TDDPCO PCO
WHERE
 EXISTS(
     SELECT 1 FROM TDDCAM CAM WHERE CAM.NUCAMPO = PCO.NUCAMPO AND CAM.NOMETAB = ?  
 )
UNION ALL
SELECT
 NUCAMPO,
 NOMECAMPO,
 DESCRCAMPO,
 NULL AS LABEL,
 ADICIONAL,
 NULL AS CHAVE,
 NULL AS VALOR,
 CAM.ORDEM AS ORDEM,
 'C' AS TIPO,
 CALCULADO,
 PERMITEPADRAO,
 APRESENTACAO,
 PERMITEPESQUISA,
 TIPCAMPO,
 VISIVELGRIDPESQUISA
FROM
 TDDCAM CAM
WHERE
 NOMETAB = ?
  
ORDER BY 1,9,8
Params:
  1 = TPRMTP
  2 = TPRMTP
  3 = TPRMTP
-------------------------------------------------------------------------------------------------------
