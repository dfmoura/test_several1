            <staticText><reportElement x="372" y="82" width="58" height="14"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[Data]]></text></staticText>
            <textField pattern="dd/MM/yyyy"><reportElement x="430" y="82" width="72" height="14"/><textElement><font size="8"/></textElement><textFieldExpression class="java.util.Date"><![CDATA[$F{DTSOL}]]></textFieldExpression></textField>

            <staticText><reportElement x="14" y="102" width="95" height="14"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[Estimativa]]></text></staticText>
            <textField><reportElement x="110" y="102" width="100" height="14"/><textElement><font size="8"/></textElement><textFieldExpression class="java.lang.String"><![CDATA[$F{ESTIMATIVA}]]></textFieldExpression></textField>

