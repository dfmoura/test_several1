<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="sub_comentarios" language="groovy" pageWidth="515" pageHeight="802" orientation="Portrait" columnWidth="515" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
    <property name="ireport.zoom" value="1.0"/>
    <property name="ireport.x" value="0"/>
    <property name="ireport.y" value="0"/>

    <parameter name="P_NUATV" class="java.math.BigDecimal"/>

    <queryString>
        <![CDATA[
SELECT
    CAST(1 AS NUMBER) AS NUATV,
    CAST(1 AS NUMBER) AS SEQUENCIA,
    TO_DATE('2026-04-15','YYYY-MM-DD') AS DATA_COMENTARIO,
    'Abertura da atividade com escopo macro validado.' AS DESCRICAO
FROM DUAL
UNION ALL
SELECT
    CAST(1 AS NUMBER) AS NUATV,
    CAST(2 AS NUMBER) AS SEQUENCIA,
    TO_DATE('2026-04-17','YYYY-MM-DD') AS DATA_COMENTARIO,
    'Solicitante pediu ajuste de layout na impressao da capa.' AS DESCRICAO
FROM DUAL
UNION ALL
SELECT
    CAST(2 AS NUMBER) AS NUATV,
    CAST(1 AS NUMBER) AS SEQUENCIA,
    TO_DATE('2026-04-20','YYYY-MM-DD') AS DATA_COMENTARIO,
    'Dependencia externa para aprovacao do template visual.' AS DESCRICAO
FROM DUAL
        ]]>
    </queryString>

    <field name="NUATV" class="java.math.BigDecimal"/>
    <field name="SEQUENCIA" class="java.math.BigDecimal"/>
    <field name="DATA_COMENTARIO" class="java.util.Date"/>
    <field name="DESCRICAO" class="java.lang.String"/>

    <filterExpression><![CDATA[$P{P_NUATV} == null || $F{NUATV}.compareTo($P{P_NUATV}) == 0]]></filterExpression>

    <background>
        <band splitType="Stretch"/>
    </background>
    <title>
        <band splitType="Stretch"/>
    </title>
    <pageHeader>
        <band splitType="Stretch"/>
    </pageHeader>

    <columnHeader>
        <band height="20" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="2" width="60" height="16"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Sequência]]></text>
            </staticText>
            <staticText>
                <reportElement x="60" y="2" width="84" height="16"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Data]]></text>
            </staticText>
            <staticText>
                <reportElement x="144" y="2" width="371" height="16"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Descrição]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="19" width="515" height="1"/>
            </line>
        </band>
    </columnHeader>

    <detail>
        <band height="18" splitType="Stretch">
            <textField>
                <reportElement x="0" y="2" width="60" height="14"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{SEQUENCIA}]]></textFieldExpression>
            </textField>
            <textField pattern="dd/MM/yyyy">
                <reportElement x="60" y="2" width="84" height="14"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression class="java.util.Date"><![CDATA[$F{DATA_COMENTARIO}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="144" y="2" width="371" height="14"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression class="java.lang.String"><![CDATA[$F{DESCRICAO}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
</jasperReport>
