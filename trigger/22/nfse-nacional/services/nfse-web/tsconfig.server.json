{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "server/dist",
    "rootDir": "server",
    "noEmit": false
  },
  "include": ["server/**/*"]
}
