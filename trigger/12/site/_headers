/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data: https://i.ytimg.com; frame-src https://www.youtube.com https://www.youtube-nocookie.com; connect-src 'self'; base-uri 'self'; form-action 'self' mailto:

/assets/css/*
  Cache-Control: public, max-age=604800

/assets/img/*
  Cache-Control: public, max-age=2592000

/favicon.ico
  Content-Type: image/x-icon

/favicon-dark.ico
  Content-Type: image/x-icon

/gestao-condominial/favicon.ico
  Content-Type: image/x-icon

/assets/img/favicon-gestao-condominial-*.png
  Content-Type: image/png

/assets/img/apple-touch-icon-gestao-condominial.png
  Content-Type: image/png

/assets/img/favicon-*.png
  Content-Type: image/png
