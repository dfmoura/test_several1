PROPRIETA AS TIMPROPRIETA,TGFPAR.TIMPROPVENDA AS TIMPROPVENDA,TGFPAR.TIMQUERCOMPRAR AS TIMQUERCOMPRAR,TGFPAR.TIMREFERENCIA01 AS TIMREFERENCIA01,TGFPAR.TIMREFERENCIA02 AS TIMREFERENCIA02,TGFPAR.TIMSENHADESC AS TIMSENHADESC,TGFPAR.TIMSENHASITE AS TIMSENHASITE,TGFPAR.TIMTELEFONE01 AS TIMTELEFONE01,TGFPAR.TIMTELEFONE02 AS TIMTELEFONE02,TGFPAR.TIMTIPOMORADIA AS TIMTIPOMORADIA,TGFPAR.TIPANEXONFE AS TIPANEXONFE,TGFPAR.TIPCLIENTESERVCOM AS TIPCLIENTESERVCOM,TGFPAR.TIPGERBOLCENT AS TIPGERBOLCENT,TGFPAR.TIPJURO AS TIPJURO,TGFPAR.TIPLOTACAO AS TIPLOTACAO,TGFPAR.TIPOFATUR AS TIPOFATUR,TGFPAR.TIPOGERBOLETO AS TIPOGERBOLETO,TGFPAR.TIPPESSOA AS TIPPESSOA,TGFPAR.TIPTRANSP AS TIPTRANSP,TGFPAR.TOLERINADIMP AS TOLERINADIMP,TGFPAR.TPCOMPRAGOV AS TPCOMPRAGOV,TGFPAR.TRANSPORTADORA AS TRANSPORTADORA,TGFPAR.TRANSPPROPRIA AS TRANSPPROPRIA,TGFPAR.TRUNCPARCELA AS TRUNCPARCELA,TGFPAR.UNIDIMPORT AS UNIDIMPORT,TGFPAR.USATABCRFORN AS USATABCRFORN,TGFPAR.USUARIO AS USUARIO,TGFPAR.UTILIZANUCADPARC AS UTILIZANUCADPARC,TGFPAR.VALDESCGRDCAR AS VALDESCGRDCAR,TGFPAR.VENDAMIN AS VENDAMIN,TGFPAR.VENDEDOR AS VENDEDOR,TGFPAR.VLRLIQITEMNFCE AS VLRLIQITEMNFCE,TGFPAR.VLRLIQITEMNFE AS VLRLIQITEMNFE,TGFPAR.VLRMINPEDCPA AS VLRMINPEDCPA, (

SELECT MAX(DOC.DTENVIADO) 

FROM AD_DOCRECEBIDOS DOC
INNER JOIN TGFPAR PAR ON DOC.CODPARC=PAR.CODPARC

WHERE DOC.CODPARC=TGFPAR.CODPARC
AND  PAR.CODPARC=TGFPAR.CODPARC) AS AD_DTAENVIADO, (
SELECT TRUNC(MAX(DTMOV),'YYYY') FROM TGFCAB
WHERE CODPARC = TGFPAR.CODPARC
AND TIPMOV = 'V'
AND STATUSNOTA = 'L'
AND STATUSNFE = 'A') AS AD_DTULTNEG, (

 SELECT
  GER.APELIDO
FROM
  TGFPAR PAR
  JOIN TGFVEN VEND ON VEND.CODVEND = PAR.CODVEND
  LEFT JOIN TGFVEN GER ON GER.CODVEND = VEND.CODGER

WHERE PAR.CODPARC=TGFPAR.CODPARC
AND PAR.CODVEND=TGFPAR.CODVEND) AS AD_GERENTE, (
SELECT  REPLACE(LISTAGG( 'Cód Veículo -  Placa -  RNTRC: '|| VEI.CODVEICULO|| '-' || VEI.PLACA || ' - ' || VEI.ANTT, CHR(10)) WITHIN GROUP (ORDER BY VEI.PLACA), CHR(10), '                                                                     
' ) AS INFORMACOES
FROM TGFVEI VEI
JOIN TGFPAR PAR ON VEI.CODPARC = PAR.CODPARC
WHERE PAR.CODPARC = TGFPAR.CODPARC
GROUP BY PAR.CODPARC) AS AD_INFVEICULO, (
SELECT
   CASE
    WHEN PAR.AD_DTVENCCAD >= TRUNC(SYSDATE)
         THEN 'CADASTRO ATUALIZADO'
    WHEN D.DTENVIADO IS NOT NULL 
         THEN 'ENVIADO PARA ANÁLISE'
    WHEN D.DTAVENCIMENTO < TRUNC(SYSDATE) 
         THEN 'DOCUMENTO VENCIDO'
    WHEN D.CODREC IS NOT NULL AND D.DTAINCLUSAO IS NOT NULL 
         THEN 'EM ANDAMENTO'
    WHEN D.CODREC IS NOT NULL AND D.DTAINCLUSAO IS NULL 
         THEN 'EM ABERTO'
    WHEN D.CODREC IS NULL 
         THEN ''
    ELSE 'SEM STATUS'
END AS STATUSDOC
FROM TGFPAR PAR
LEFT JOIN (
    SELECT CODPARC,
           MAX(DTAINCLUSAO) AS DTAINCLUSAO,
           MAX(DTENVIADO) KEEP (DENSE_RANK LAST ORDER BY DTAINCLUSAO, CODREC) AS DTENVIADO,
           MAX(DTAVENCIMENTO) KEEP (DENSE_RANK LAST ORDER BY DTAINCLUSAO, CODREC) AS DTAVENCIMENTO,
           MAX(CODREC) KEEP (DENSE_RANK LAST ORDER BY DTAINCLUSAO, CODREC) AS CODREC
      FROM AD_DOCRECEBIDOS
     GROUP BY CODPARC
) D
   ON D.CODPARC = TGFPAR.CODPARC

WHERE PAR.CODPARC=TGFPAR.CODPARC) AS AD_STATUSCAD, (
SELECT UFS.UF
FROM TSIUFS UFS
, TSICID CID
WHERE CID.UF = UFS.CODUF
AND CID.CODCID = TGFPAR.CODCID) AS AD_UF FROM TGFPAR /*SQL_92_JOINED_TABLES*/  WHERE (TGFPAR.CODPARC = ?)
Params:
  1 = 1
