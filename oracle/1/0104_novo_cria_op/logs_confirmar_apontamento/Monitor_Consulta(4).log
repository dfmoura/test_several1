SELECT TGFSER.ATUALESTOQUE AS ATUALESTOQUE,TGFSER.AVARIADO AS AVARIADO,TGFSER.CODATVPCM AS CODATVPCM,TGFSER.CODPROD AS CODPROD,TGFSER.CODUSU AS CODUSU,TGFSER.DTALTER AS DTALTER,TGFSER.NUNOTA AS NUNOTA,TGFSER.SEQUENCIA AS SEQUENCIA,TGFSER.SERIE AS SERIE,TGFSER.SERIEFAB AS SERIEFAB,TGFSER.SMARTCARD AS SMARTCARD FROM TGFSER /*SQL_92_JOINED_TABLES*/   WHERE (TGFSER.NUNOTA = ? AND TGFSER.ATUALESTOQUE = 0) 
Params:
  1 = 162253
-------------------------------------------------------------------------------------------------------
##ID_1689## tempo: 28 (ms)
/* Runtime-info
Application: OperacaoProducao
Referer: https://satis2.nuvemdatacom.com.br:8110/mgeprod/OperacaoProducao.xhtml5
ResourceID: br.com.sankhya.producao.cad.OperacaoProducao
service-name: OperacaoProducaoSP.confirmarApontamento
uri: /mgeprod/service.sbr
*/
WITH PRO
AS (
	SELECT DISTINCT CODPROD, CODLOCALORIG 
	FROM TGFITE I
	WHERE NUNOTA = ?
		
		
		AND (
			SELECT CASE 
					WHEN PRO.TIPCONTEST IN ('E','C') OR (PRO.TIPCONTEST = 'L' AND PRO.WMSPRODRASTSERMED = 'S' AND ? = 'S')
					THEN 'S'
					ELSE 'N'
					END
			FROM TGFPRO PRO
			WHERE PRO.CODPROD = I.CODPROD
			) = 'S'
		
)
SELECT  * FROM (
    SELECT ITE.CODEMP
        ,SER.CODPROD
        ,SER.SERIE
        ,NULL AS CODLOCAL
        ,SUM(SER.ATUALESTOQUE) ATUALESTOQUE
        ,'GLOBAL' AS TIPO
    FROM TGFSER SER
    , TGFITE ITE
    , (SELECT DISTINCT CODPROD FROM PRO) PRO
    WHERE SER.CODPROD = PRO.CODPROD
    AND ITE.NUNOTA = SER.NUNOTA
    AND ITE.SEQUENCIA = SER.SEQUENCIA
    GROUP BY ITE.CODEMP, SER.CODPROD ,SER.SERIE
    HAVING (SUM(SER.ATUALESTOQUE) > 1) OR (SUM(SER.ATUALESTOQUE) < 0)

    UNION ALL

    SELECT ITE.CODEMP
        ,SER.CODPROD
        ,SER.SERIE
        ,ITE.CODLOCALORIG CODLOCAL
        ,SUM(SER.ATUALESTOQUE)
        ,'LOCAL' AS TIPO
    FROM TGFSER SER
    , TGFITE ITE
    , PRO
    WHERE SER.CODPROD = PRO.CODPROD
        AND ITE.NUNOTA = SER.NUNOTA
        AND ITE.SEQUENCIA = SER.SEQUENCIA
        AND ITE.CODLOCALORIG = PRO.CODLOCALORIG
    GROUP BY ITE.CODEMP, SER.CODPROD, SER.SERIE, ITE.CODLOCALORIG
    HAVING (SUM(SER.ATUALESTOQUE) > 1) OR (SUM(SER.ATUALESTOQUE) < 0)

) SER
 WHERE ROWNUM = 1 


Params:
  1 = 162253
  2 = N
-------------------------------------------------------------------------------------------------------
