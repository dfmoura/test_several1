				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[Funcoes.pdes(
    $P{JDBC_CONNECTION},
    "'Itens                          | Qtde | Vrl. Unit.   | Vlr. Total' "
    + "|| CHR(10) || "
    + "LISTAGG("
    + "RPAD(PRO.DESCRPROD,30) || ' | ' || "
    + "LPAD(ITE.QTDNEG,4) || ' | ' || "
    + "LPAD(TO_CHAR(ITE.VLRUNIT,'FM999G999G990D00'),12) || ' | ' || "
    + "LPAD(TO_CHAR(ITE.VLRTOT,'FM999G999G990D00'),12), "
    + "CHR(10)) WITHIN GROUP (ORDER BY PRO.DESCRPROD)",
    "TGFCAB CAB "
    + "INNER JOIN TGFITE ITE ON CAB.NUNOTA = ITE.NUNOTA "
    + "INNER JOIN TGFPRO PRO ON ITE.CODPROD = PRO.CODPROD",
    "ITE.NUNOTA = " + $P{NUNOTA}
)]]></textFieldExpression>
			</textField>
			<line>
				<reportElement x="1" y="49" width="555" height="1"/>
			</line>
