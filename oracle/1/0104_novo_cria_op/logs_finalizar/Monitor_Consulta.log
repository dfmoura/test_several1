SELECT FORMULARIO.NOMETAB, FORMU.DESCRICAO FROM TPRFORM FORMU 		INNER JOIN ( 			SELECT NOMEINSTANCIA, NOMETAB 	 			FROM TDDINS INS 	 		WHERE TIPOFORM IS NOT NULL 	 	) FORMULARIO ON (FORMULARIO.NOMEINSTANCIA = FORMU.NOMEINSTANCIAREF) 	 	INNER JOIN TPRFRME FRME ON (FORMU.IDFORM = FRME.IDFORM) WHERE FORMU.IDPROC = ? 	AND FRME.IDEFX = ? 	AND FORMU.TIPOFORM = 'A' 	AND FRME.OBRIGATORIO = 'S' 
