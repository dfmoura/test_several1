	<property name="ireport.definition"/>
	<parameter name="NUNOTA" class="java.math.BigDecimal" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT PRO.DESCRPROD AS PRODUTO,
       ITE.VLRUNIT AS  VLRUNIT,
       ITE.VLRTOT AS VLRTOTAL,
       ITE.QTDNEG AS VOLUME
 FROM TGFITE ITE
  LEFT JOIN TGFPRO PRO ON ITE.CODPROD = PRO.CODPROD
   WHERE ITE.NUNOTA = $P{NUNOTA}]]>
	</queryString>
	<field name="PRODUTO" class="java.lang.String">
