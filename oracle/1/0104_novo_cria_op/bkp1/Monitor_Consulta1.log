SELECT TPRAMP.CODLOCALBAIXA AS CODLOCALBAIXA,TPRAMP.CODMPE AS CODMPE,TPRAMP.CODPRODMP AS CODPRODMP,TPRAMP.CODVOL AS CODVOL,TPRAMP.CONTROLEMP AS CONTROLEMP,TPRAMP.NUAPO AS NUAPO,TPRAMP.QTD AS QTD,TPRAMP.QTDMPE AS QTDMPE,TPRAMP.QTDPERDA AS QTDPERDA,TPRAMP.SEQAPA AS SEQAPA,TPRAMP.SEQMP AS SEQMP,TPRAMP.TIPOUSO AS TIPOUSO,TPRAMP.VINCULOSERIEPA AS VINCULOSERIEPA, (
SELECT SUM(EST.ESTOQUE)  AS ESTOQUE
FROM TGFEST EST 
WHERE (EST.CONTROLE=TPRAMP.CONTROLEMP OR TPRAMP.CONTROLEMP = ' ') 
AND EST.CODPROD=TPRAMP.CODPRODMP
AND EST.ESTOQUE > 0) AS AD_ESTOQUE, ( SELECT REFERENCIA FROM TGFPRO PRO WHERE CODPROD = TPRAMP.CODPRODMP) AS REFERENCIA , LocalBaixaMPProducao.DESCRLOCAL AS l0_DESCRLOCAL,MotivosPerda.DESCRICAO AS l1_DESCRICAO,MotivosPerda.DESCRICAO AS l1_DESCRICAO,ProdutoMateriaPrima.DESCRPROD AS l2_DESCRPROD,ProdutoMateriaPrima.DECQTD AS l2_DECQTD,Volume.DESCRVOL AS l3_DESCRVOL FROM TPRAMP  left join (SELECT DESCRLOCAL,CODLOCAL FROM TGFLOC) LocalBaixaMPProducao  ON(TPRAMP.CODLOCALBAIXA = LocalBaixaMPProducao.CODLOCAL) left join (SELECT CODMPE,DESCRICAO FROM TPRMPE) MotivosPerda  ON(TPRAMP.CODMPE = MotivosPerda.CODMPE) left join (SELECT DESCRPROD,DECQTD,CODPROD FROM TGFPRO) ProdutoMateriaPrima  ON(TPRAMP.CODPRODMP = ProdutoMateriaPrima.CODPROD) left join (SELECT DESCRVOL,CODVOL FROM TGFVOL) Volume  ON(TPRAMP.CODVOL = Volume.CODVOL)   WHERE (( (TPRAMP.NUAPO = ?)  AND  (TPRAMP.SEQAPA = ?) )) 
