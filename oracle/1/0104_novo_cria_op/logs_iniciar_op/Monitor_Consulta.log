TV,IDEFX FROM TPRIATV) InstanciaAtividade  ON(TPRROPE.IDIATV = InstanciaAtividade.IDIATV) left join (SELECT IDEFX FROM TPRATV) Atividade7_1  ON(InstanciaAtividade.IDEFX = Atividade7_1.IDEFX) left join (SELECT TIPO,IDEFX FROM TPREFX) ElementoFluxo7_2  ON(Atividade7_1.IDEFX = ElementoFluxo7_2.IDEFX)  ,TGFCAB R0_CabecalhoNota  WHERE (((TPRROPE.NUNOTA = R0_CabecalhoNota.NUNOTA)) and ((TPRROPE.NUNOTA IS NOT NULL AND R0_CabecalhoNota.TIPMOV <> 'F' AND TPRROPE.IDIATV IN (SELECT ATV.IDIATV FROM TPRIATV ATV WHERE ATV.IDIPROC = 16198) AND 	TPRROPE.SEQROPE = (		SELECT MIN(ROPE.SEQROPE) AS SEQROPE		FROM TPRROPE ROPE		WHERE ROPE.IDIATV = TPRROPE.IDIATV			AND ROPE.IDEFX = TPRROPE.IDEFX			AND ROPE.SEQOPER = TPRROPE.SEQOPER			AND ROPE.CODPRODPA = TPRROPE.CODPRODPA			AND ROPE.NUNOTA = TPRROPE.NUNOTA		GROUP BY ROPE.IDIATV, ROPE.IDEFX, ROPE.SEQOPER, ROPE.CODPRODPA, ROPE.NUNOTA))))  ORDER BY TPRROPE.NUNOTA DESC
