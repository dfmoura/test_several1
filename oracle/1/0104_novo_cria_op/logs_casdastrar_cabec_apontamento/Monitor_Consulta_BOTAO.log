service-name: GridConfig.getGridConfigFromJson
uri: /mge/service.sbr
*/
SELECT
	PROP.NOME,
	PROP.VALOR
FROM
	TRDCON CTR
	INNER JOIN TRDPCO PCO2
		ON (CTR.NUCONTROLE = PCO2.NUCONTROLE AND PCO2.NOME = 'resourceID')
	INNER JOIN TRDPCO PROP
		ON (CTR.NUCONTROLE = PROP.NUCONTROLE AND PROP.NOME = 'legacyResourceID')
WHERE
	CTR.TIPOCONTROLE = 'MN'
	AND PCO2.VALOR = ?
