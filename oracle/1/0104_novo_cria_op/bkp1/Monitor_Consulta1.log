SELECT SUM (NVL(APA.QTDAPONTADA,0) + NVL(APA_PERDA.QTDPERDA,0)) AS SOMAQTDAPONTADA  FROM TPRIPA IPA,     (SELECT SUM(APA.QTDAPONTADA) AS QTDAPONTADA           FROM TPRAPA APA       WHERE EXISTS ( SELECT APO.NUAPO                            FROM TPRAPO APO                            INNER JOIN TPRIATV IATV ON (IATV.IDIATV = APO.IDIATV)                        WHERE APO.NUAPO   = APA.NUAPO                        AND IATV.IDEFX = ? AND IATV.IDIPROC = ?                        AND APA.CODPRODPA = ?                        AND APA.CONTROLEPA = ?                   )     ) APA,     (SELECT SUM(APA.QTDPERDA) AS QTDPERDA         FROM TPRAPA APA         INNER JOIN TPRAPO APO ON (APO.NUAPO = APA.NUAPO)     WHERE EXISTS (SELECT 1          FROM TPRIATV IATV              WHERE IATV.IDIPROC = ?                 AND APO.IDIATV = IATV.IDIATV             )           AND APA.CODPRODPA = ?           AND APA.CONTROLEPA = ?     ) APA_PERDA  WHERE IPA.IDIPROC   = ?  AND IPA.CODPRODPA = ?  AND IPA.CONTROLEPA = ? 
