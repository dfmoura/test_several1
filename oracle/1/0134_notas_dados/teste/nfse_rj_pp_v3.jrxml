	<parameter name="NUNOTA" class="java.math.BigDecimal" isForPrompting="false">
		<defaultValueExpression><![CDATA[new BigDecimal(188383)]]></defaultValueExpression>
	</parameter>
	<parameter name="PDIR_MODELO" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
  CIDEMP.NOMECID AS CIDEMP,
  CIDPARC.NOMECID AS CIDPARC,
  NFSE.XMLNFSE,
CAB.OBSERVACAO AS OBS_NOTA,
NVL(EMP.AD_LOGONFSE, 'logo.png') AS AD_LOGONFSE
FROM
  TGFCAB CAB
INNER JOIN TGFNFSE NFSE ON (CAB.NUNOTA = NFSE.NUNOTA)
INNER JOIN TSIEMP EMP ON (CAB.CODEMP = EMP.CODEMP)
INNER JOIN TGFPAR PARC ON (CAB.CODPARC = PARC.CODPARC)
INNER JOIN TSICID CIDEMP ON (EMP.CODCID = CIDEMP.CODCID)
INNER JOIN TSICID CIDPARC ON (PARC.CODCID = CIDPARC.CODCID)
WHERE
  CAB.NUNOTA = $P{NUNOTA}]]>
	</queryString>
	<field name="CIDEMP" class="java.lang.String"/>
	<field name="CIDPARC" class="java.lang.String"/>
	<field name="XMLNFSE" class="java.sql.Clob"/>
	<field name="OBS_NOTA" class="java.lang.String"/>
	<field name="AD_LOGONFSE" class="java.lang.String"/>
