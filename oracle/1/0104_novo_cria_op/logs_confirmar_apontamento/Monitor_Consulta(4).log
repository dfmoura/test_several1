SELECT DISTINCT LMP.TIPOQTD, LMP.CONSUREFUGO, LMP.ESTOQUETERCEIRO
FROM TPRLMP LMP LEFT JOIN TPRMPA MPA 
				ON (LMP.IDEFX = MPA.IDEFX
					AND LMP.CODPRODPA = MPA.CODPRODPA 
					AND NVL(LMP.CONTROLEPA, ' ') = NVL(MPA.CONTROLEPA, ' ')
					AND LMP.CODPRODMP = MPA.CODPRODMP 
					AND NVL(LMP.CONTROLEMP, ' ') = NVL(MPA.CONTROLEMP, ' ') 
				)
WHERE LMP.IDEFX IN (SELECT IDEFX FROM TPRIATV WHERE IDIPROC = ?) 
  AND LMP.CODPRODPA = ? 
  AND (((LMP.CODPRODMP = ? AND NVL(LMP.CONTROLEMP, ' ') = ?)
       	OR (MPA.CODPRODMPALT = ? AND NVL(MPA.CONTROLEMPALT, ' ') = ?)
       ) OR (	LMP.TIPOCONTROLEMP IN ('I', 'H') 
   				AND ((LMP.CODPRODMP = ? AND NVL(LMP.CONTROLEMP, ' ') = ' ')
   					OR (MPA.CODPRODMPALT = ? AND NVL(MPA.CONTROLEMPALT, ' ') = ' ')
   				)
			) 
       )
