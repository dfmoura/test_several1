SELECT TPRIPROC.AD_DTFABRICACAO AS AD_DTFABRICACAO,TPRIPROC.AD_LOTEPI AS AD_LOTEPI,TPRIPROC.AD_OBSERVACAO AS AD_OBSERVACAO,TPRIPROC.AD_QUALIDADE AS AD_QUALIDADE,TPRIPROC.CODPARC AS CODPARC,TPRIPROC.CODPLP AS CODPLP,TPRIPROC.CODUSUFINAL AS CODUSUFINAL,TPRIPROC.CODUSUINC AS CODUSUINC,TPRIPROC.DHINC AS DHINC,TPRIPROC.DHINST AS DHINST,TPRIPROC.DHTERMINO AS DHTERMINO,TPRIPROC.DTINICIOMAX AS DTINICIOMAX,TPRIPROC.DTPREVENT AS DTPREVENT,TPRIPROC.IDICOP AS IDICOP,TPRIPROC.IDIPROC AS IDIPROC,TPRIPROC.IDIPROCPAI AS IDIPROCPAI,TPRIPROC.IDPROC AS IDPROC,TPRIPROC.IDWFLOW AS IDWFLOW,TPRIPROC.NROLOTE AS NROLOTE,TPRIPROC.NUMPS AS NUMPS,TPRIPROC.NUNOTA AS NUNOTA,TPRIPROC.PRIORIDADE AS PRIORIDADE,TPRIPROC.SEQNOTA AS SEQNOTA,TPRIPROC.STATUSPROC AS STATUSPROC,TPRIPROC.TEMPOATRAVESS AS TEMPOATRAVESS, ( select sum(estoque-reservado) from tgfest where CONTROLE =  TPRIPROC.NROLOTE AND CODPROD = (SELECT CODPRODPA FROM TPRIPA WHERE IDIPROC = TPRIPROC.IDIPROC) AND CODEMP = TPRIPROC.CODPLP) AS AD_ESTOQUE, ( select idiprocpi from TPRIDEP where idiprocpa = TPRIPROC.IDIPROC) AS AD_IDIPROCPI, (
SELECT
LISTAGG(RAM.NURAM, ', ')
FROM TPRIPA PA
LEFT JOIN TGFRAM RAM ON RAM.CODPROD = PA.CODPRODPA AND RAM.CONTROLE = PA.NROLOTE
WHERE PA.IDIPROC = TPRIPROC.IDIPROC) AS AD_NURAM, (CASE WHEN TPRIPROC.CODPARCTERC IS NULL THEN (SELECT CODPARCTERC FROM TPRTXAT TXAT WHERE TXAT.IDIPROC = TPRIPROC.IDIPROC AND IDEFX = 0) ELSE TPRIPROC.CODPARCTERC END) AS CODPARCTERC , AD_LOTESPI.DESCRPROD AS l0_DESCRPROD,Parceiro2.NOMEPARC AS l1_NOMEPARC,PlantaManufatura.NOME AS l2_NOME,ProcessoProdutivo.DESCRABREV AS l3_DESCRABREV,ProcessoProdutivo.CODPRC AS l3_CODPRC,ProcessoProdutivo.TIPOPROC AS l3_TIPOPROC,ProcessoProdutivo.DESCRABREV AS l3_DESCRABREV,ProcessoProdutivo.VERSAO AS l3_VERSAO,ProcessoProdutivo.CODPLP AS l3_CODPLP,ProcessoProdutivo.TIPONROLOTE AS l3_TIPONROLOTE,ProcessoProdutivo.PRODPARATERCEIRO AS l3_PRODPARATERCEIRO,ProcessoProdutivo.USATERCEIRO AS l3_USATERCEIRO,ProcessoProdutivo.DEFTERCEIRO AS l3_DEFTERCEIRO,ProcessoProdutivo.TIPEXECATV AS l3_TIPEXECATV,Usuario.NOMEUSU AS l4_NOMEUSU,Usuario2.NOMEUSU AS l5_NOMEUSU FROM TPRIPROC  left join (SELECT DESCRPROD,ID FROM AD_LOTESPI) AD_LOTESPI  ON(TPRIPROC.AD_LOTEPI = AD_LOTESPI.ID) left join (SELECT NOMEPARC,CODPARC FROM TGFPAR) Parceiro2  ON(TPRIPROC.CODPARC = Parceiro2.CODPARC) left join (SELECT CODPLP,NOME FROM TPRPLP) PlantaManufatura  ON(TPRIPROC.CODPLP = PlantaManufatura.CODPLP) left join (SELECT TIPONROLOTE,CODPLP,IDPROC,DESCRABREV,TIPOPROC,CODPRC,DEFTERCEIRO,TIPEXECATV,USATERCEIRO,PRODPARATERCEIRO,VERSAO FROM TPRPRC) ProcessoProdutivo  ON(TPRIPROC.IDPROC = ProcessoProdutivo.IDPROC) left join (SELECT CODUSU,NOMEUSU FROM TSIUSU) Usuario  ON(TPRIPROC.CODUSUFINAL = Usuario.CODUSU) left join (SELECT CODUSU,NOMEUSU FROM TSIUSU) Usuario2  ON(TPRIPROC.CODUSUINC = Usuario2.CODUSU)   WHERE ((((TPRIPROC.STATUSPROC NOT IN('AP', 'P'))  AND TPRIPROC.IDIPROC = ?))) 
