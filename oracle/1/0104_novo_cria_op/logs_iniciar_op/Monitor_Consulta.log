/* Runtime-info
Application: OrdensProducao
Referer: https://satis2.nuvemdatacom.com.br:8110/mgeprod/OrdensProducao.xhtml5
ResourceID: br.com.sankhya.prod.OrdensProducaoHTML
service-name: OperacaoProducaoSP.getAtividadesCards
uri: /mgeprod/service.sbr
*/
SELECT IATV.IDIATV,
	   IPROC.IDIPROC,
	   IPROC.STATUSPROC,
	   EFX.IDEFX,
	   IPROC.IDPROC,
	   EFX.DESCRICAO,
	   IATV.DHINCLUSAO,
	   IATV.DHINICIO,
	   IATV.DHFINAL,
	   (CASE 
		   WHEN (IATV.DHFINAL is NOT NULL) THEN 0 
	       WHEN (IATV.DHFINAL is NULL) THEN (SELECT 
		   ESR.ESTOQUE 
		   FROM TPRESR ESR
		   WHERE
		   ESR.CODPRODPA = IPA.CODPRODPA
		   AND ESR.CONTROLEPA = IPA.CONTROLEPA
		   AND ESR.IDRPA = ATV.IDRPAOPER
		   AND ESR.IDIPROC = IPROC.IDIPROC
	   ) END) AS QTDOPERACAO,
		(SELECT 
		   NVL(SUM(MER.QTD),0) 
		   FROM TPRMER MER
		   INNER JOIN TPRIATV IATV2 ON(MER.IDIATV = IATV2.IDIATV)
		   INNER JOIN TPREFX EFX ON(IATV2.IDEFX = EFX.IDEFX)
		    WHERE 
		    MER.IDIPROC = IPROC.IDIPROC
		    AND IATV2.IDIATV = IATV.IDIATV
		    AND MER.CODPRODPA = IPA.CODPRODPA
			AND MER.CONTROLEPA = IPA.CONTROLEPA
		    AND MER.SINAL = -1
		) AS QTDAPONTADA,
		(SELECT 
		   NVL(SUM(APA.QTDPERDA),0) 
		   FROM TPRAPA APA
		   INNER JOIN TPRAPO APO ON(APO.NUAPO = APA.NUAPO)
		   INNER JOIN TPRIATV IAT ON(IAT.IDIATV = APO.IDIATV)
		   WHERE
		   APA.CODPRODPA = IPA.CODPRODPA
		   AND APA.CONTROLEPA = IPA.CONTROLEPA
		   AND APO.SITUACAO = 'C'
		   AND IAT.IDIPROC =  IPROC.IDIPROC
		   AND IAT.IDEFX = EFX.IDEFX
		   AND IAT.IDIATV = IATV.IDIATV
		) AS QTDPERDIDA,
		PRO.DECQTD,
		ATV.APONTAMP,
		ATV.APONTASP,
		ATV.PERMITEPARCIAL,
		ATV.MULTITURNO,
		ATV.CODMTPFINTURNO,
		IPA.QTDPRODUZIR,
		IPA.CODPRODPA,
		IPA.CONTROLEPA,
		(CASE WHEN (SELECT COUNT(*) FROM TPRAPO WHERE IDIATV = IATV.IDIATV) > 0 THEN 'true' 
		ELSE 'false' END) AS EXIST_CAB_APONT,
		IATV.CODWCP,
		(SELECT WCP.NOME FROM TPRWCP WCP  WHERE WCP.CODWCP = IATV.CODWCP) AS DESCWCP,
		EFX.TIPO
FROM TPRIPROC IPROC INNER JOIN TPRATV ATV ON (ATV.IDPROC = IPROC.IDPROC)
				  INNER JOIN TPRIATV IATV ON (IATV.IDIPROC = IPROC.IDIPROC AND IATV.IDEFX = ATV.IDEFX)
				  INNER JOIN TPREFX EFX ON (EFX.IDEFX = ATV.IDEFX)
				  INNER JOIN TPRIPA IPA ON (IPA.IDIPROC = IPROC.IDIPROC)
				  INNER JOIN TGFPRO PRO ON (PRO.CODPROD = IPA.CODPRODPA)
WHERE IPROC.IDIPROC = ?
AND EFX.TIPO <> '1111'
ORDER BY ATV.SEQEXECUCAO DESC, IATV.DHINICIO DESC
Params:
  1 = 16198
