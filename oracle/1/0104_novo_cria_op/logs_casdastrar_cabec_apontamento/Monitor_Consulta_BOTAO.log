SELECT TPRAMP.CODLOCALBAIXA AS CODLOCALBAIXA,TPRAMP.CODMPE AS CODMPE,TPRAMP.CODPRODMP AS CODPRODMP,TPRAMP.CODVOL AS CODVOL,TPRAMP.CONTROLEMP AS CONTROLEMP,TPRAMP.NUAPO AS NUAPO,TPRAMP.QTD AS QTD,TPRAMP.QTDMPE AS QTDMPE,TPRAMP.QTDPERDA AS QTDPERDA,TPRAMP.SEQAPA AS SEQAPA,TPRAMP.SEQMP AS SEQMP,TPRAMP.TIPOUSO AS TIPOUSO,TPRAMP.VINCULOSERIEPA AS VINCULOSERIEPA, (
