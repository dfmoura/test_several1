SELECT TPRARW.CODCRE AS CODCRE,TPRARW.CODWCP AS CODWCP,TPRARW.NUAPO AS NUAPO,TPRARW.QTDAPONTADA AS QTDAPONTADA,TPRARW.QTDRECAPONTAR AS QTDRECAPONTAR,TPRARW.SEQAPA AS SEQAPA, (  SELECT CRE.CODVOL FROM TPRCRE CRE WHERE CRE.CODCRE = TPRARW.CODCRE) AS CODVOL, ( SELECT COUNT (1) FROM TPRIARW IARW WHERE IARW.NUAPO = TPRARW.NUAPO AND IARW.SEQAPA = TPRARW.SEQAPA AND IARW.CODWCP = TPRARW.CODWCP AND IARW.CODCRE = TPRARW.CODCRE) AS QTDITENSREC, ( TPRARW.QTDAPONTADA * (SELECT COUNT (1) FROM TPRIARW IARW WHERE IARW.NUAPO = TPRARW.NUAPO AND IARW.SEQAPA = TPRARW.SEQAPA AND IARW.CODWCP = TPRARW.CODWCP AND IARW.CODCRE = TPRARW.CODCRE)) AS QTDUTILIZADA , CategoriaRecurso.NOME AS l0_NOME,CategoriaRecurso.TIPO AS l0_TIPO,CategoriaRecurso.CODSERVAPONTA AS l0_CODSERVAPONTA,CategoriaRecurso.CODVOL AS l0_CODVOL,CategoriaRecurso.DECQTD AS l0_DECQTD,Volume1_1.DESCRVOL AS l1_DESCRVOL,WorkCenter.NOME AS l2_NOME,WorkCenter.CODPLP AS l2_CODPLP FROM TPRARW  left join (SELECT CODCRE,TIPO,CODSERVAPONTA,CODVOL,DECQTD,NOME FROM TPRCRE) CategoriaRecurso  ON(TPRARW.CODCRE = CategoriaRecurso.CODCRE) left join (SELECT DESCRVOL,CODVOL FROM TGFVOL) Volume1_1  ON(CategoriaRecurso.CODVOL = Volume1_1.CODVOL) left join (SELECT CODWCP,CODPLP,NOME FROM TPRWCP) WorkCenter  ON(TPRARW.CODWCP = WorkCenter.CODWCP)   WHERE (( (TPRARW.NUAPO = ?)  AND  (TPRARW.SEQAPA = ?) )) 
