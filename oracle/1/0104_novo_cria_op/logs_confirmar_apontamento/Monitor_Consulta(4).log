SELECT
    SUM(CASE WHEN DIN.CODIMP = 15 THEN DIN.VALOR ELSE 0 END) AS VIS,
    SUM(CASE WHEN DIN.CODIMP = m.MIN_CODIMP  AND NVL(DIN.INDGIBSCBS, CST.INDGIBSCBS) = 'S'  THEN DIN.BASERED ELSE 0 END) AS VBCIBSCBS,
    SUM(CASE WHEN DIN.CODIMP = 12  AND NVL(DIN.INDGIBSCBS, CST.INDGIBSCBS) = 'S'  THEN DIN.VLRDIF ELSE 0 END) AS VDIFIBSUF,
    SUM(CASE WHEN DIN.CODIMP = 12  AND NVL(DIN.INDGIBSCBS, CST.INDGIBSCBS) = 'S'  THEN DIN.VLRDEVTRIB ELSE 0 END) AS VDEVTRIBIBSUF,
    SUM(CASE WHEN DIN.CODIMP = 12  AND NVL(DIN.INDGIBSCBS, CST.INDGIBSCBS) = 'S'  THEN DIN.VALOR ELSE 0 END) AS VIBSUF,
    SUM(CASE WHEN DIN.CODIMP = 13  AND NVL(DIN.INDGIBSCBS, CST.INDGIBSCBS) = 'S'  THEN DIN.VLRDIF ELSE 0 END) AS VDIFIBSMUN,
    SUM(CASE WHEN DIN.CODIMP = 13 THEN DIN.VLRDEVTRIB ELSE 0 END) AS VDEVTRIBIBSMUN,
    SUM(CASE WHEN DIN.CODIMP = 13  AND NVL(DIN.INDGIBSCBS, CST.INDGIBSCBS) = 'S'  THEN DIN.VALOR ELSE 0 END) AS VIBSMUN,
     SUM(CASE WHEN DIN.CODIMP IN (12,13) AND NVL(DIN.INDGIBSCBS, CST.INDGIBSCBS) = 'S' THEN NVL(DIN.VLRDEDUZCREDPRES, DIN.VALOR) ELSE  0 END) AS VIBS, 
    
    SUM(CASE WHEN DIN.CODIMP IN (12,13) THEN DIN.VCREDPRES ELSE 0 END) AS VCREDPRESIBS,
     SUM(CASE WHEN DIN.CODIMP IN (12,13) AND NVL(DIN.INDGIBSCBS, CST.INDGIBSCBS) = 'S' THEN NVL(DIN.VLRDEDUZCREDPRES, DIN.VALOR) ELSE 0 END) AS VLRDEDUZCREDPRESIBS, 
    
    0 AS VCRDPRESCONSUSIBS,
    SUM(CASE WHEN DIN.CODIMP = 14  AND NVL(DIN.INDGIBSCBS, CST.INDGIBSCBS) = 'S'  THEN DIN.VLRDIF ELSE 0 END) AS VDIFCBS,
    SUM(CASE WHEN DIN.CODIMP = 14  AND NVL(DIN.INDGIBSCBS, CST.INDGIBSCBS) = 'S'  THEN DIN.VLRDEVTRIB ELSE 0 END) AS VDEVTRIBCBS,
    SUM(CASE WHEN DIN.CODIMP = 14  AND NVL(DIN.INDGIBSCBS, CST.INDGIBSCBS) = 'S'  THEN DIN.VALOR ELSE 0 END) AS VCBS,
    SUM(CASE WHEN DIN.CODIMP = 14 THEN DIN.VCREDPRES ELSE 0 END) AS VCREDPRESCBS,
     SUM(CASE WHEN DIN.CODIMP = 14 AND NVL(DIN.INDGIBSCBS, CST.INDGIBSCBS) = 'S' THEN NVL(DIN.VLRDEDUZCREDPRES, DIN.VALOR) ELSE 0 END) AS VLRDEDUZCREDPRESCBS, 
    
    0 AS VCRDPRESCONSUSCBS,
    SUM(CASE WHEN DIN.CODIMP = 16 THEN DIN.VLRMONO ELSE 0 END) AS VIBSMONO,
    SUM(CASE WHEN DIN.CODIMP = 17 THEN DIN.VLRMONO ELSE 0 END) AS VCBSMONO,
    SUM(CASE WHEN DIN.CODIMP = 16 THEN DIN.VLRMONOSR ELSE 0 END) AS VIBSMONORETEN,
    SUM(CASE WHEN DIN.CODIMP = 17 THEN DIN.VLRMONOSR ELSE 0 END) AS VCBSMONORETEN,
    SUM(CASE WHEN DIN.CODIMP = 16 THEN DIN.VLRRETANT ELSE 0 END) AS VIBSMONORET,
    SUM(CASE WHEN DIN.CODIMP = 17 THEN DIN.VLRRETANT ELSE 0 END) AS VCBSMONORET
FROM TGFDIN DIN
         LEFT JOIN (
    SELECT MIN(CODIMP) AS MIN_CODIMP
    FROM TGFDIN
    WHERE NUNOTA = ?
      AND CODIMP IN (12, 13, 14, 16, 17)
      AND CODINC IN (0, 1, 2)
) m ON 1=1
LEFT JOIN TLFCSTIC CST ON CST.CODCST = DIN.CODCST

 INNER JOIN TGFITE ITE ON (ITE.NUNOTA = DIN.NUNOTA AND ITE.SEQUENCIA = DIN.SEQUENCIA) 
WHERE DIN.NUNOTA = ?
  AND DIN.CODIMP IN (12, 13, 14, 15, 16, 17)
  AND DIN.SEQUENCIA > 0
 AND NOT EXISTS (SELECT 1 FROM TGFVAR VAR WHERE VAR.NUNOTA = ITE.NUNOTA AND VAR.NUNOTAORIG = ITE.NUNOTA AND VAR.SEQUENCIAORIG = ITE.SEQUENCIA) 

Params:
  1 = 162253
  2 = 162253
