##ID_266## tempo: 32 (ms)
/* Runtime-info
Application: OperacaoProducao
Referer: https://satis2.nuvemdatacom.com.br:8110/mgeprod/OperacaoProducao.xhtml5
ResourceID: br.com.sankhya.producao.cad.OperacaoProducao
service-name: OperacaoProducaoSP.confirmarApontamento
uri: /mgeprod/service.sbr
*/
 SELECT IPA.CODPRODPA 
        , IPA.CONTROLEPA 
        , ROUND(SUM (APA.QTDAPONTADA) + SUM(APA_PERDA.QTDPERDA) - SUM (IPA.QTDPRODUZIR), NVL(PROD.DECQTD, 8)) AS TOTAL_APONTADO 
        , (SELECT ATV.PROIBEAPONT 
            FROM TPRATV ATV INNER JOIN TPRIATV IATV ON (ATV.IDEFX = IATV.IDEFX)  
            WHERE IATV.IDIATV = ?) AS PROIBEAPONT 
        , (SELECT ROUND(SUM(QTDAPONTADA + QTDPERDA), NVL(PROD.DECQTD, 8))
                 FROM TPRAPO APO
                 INNER JOIN TPRAPA APA ON(APO.NUAPO = APA.NUAPO)
                 INNER JOIN TPRIATV IATV ON(IATV.IDIATV = APO.IDIATV)
                 WHERE IATV.IDEFX = ?
                 AND IATV.IDIPROC = ?
                 AND APA.CODPRODPA = IPA.CODPRODPA
                 AND APA.CONTROLEPA = IPA.CONTROLEPA) - SUM (IPA.QTDPRODUZIR) AS SOMAQTDAPONTADA
     FROM TPRIPA IPA, TGFPRO PROD,
         (SELECT APA.CODPRODPA, APA.CONTROLEPA,SUM(APA.QTDAPONTADA) AS QTDAPONTADA 
               FROM TPRAPA APA  
           WHERE EXISTS ( SELECT APO.NUAPO 
                                FROM TPRAPO APO 
                            WHERE APO.NUAPO   = APA.NUAPO 
                            AND APO.IDIATV = ? 
                       )
            AND APA.CODPRODPA = ?
            AND APA.CONTROLEPA = ?
            GROUP BY CODPRODPA,CONTROLEPA
         ) APA, 
         (SELECT APA.CODPRODPA, APA.CONTROLEPA,SUM(APA.QTDPERDA) AS QTDPERDA 
             FROM TPRAPA APA 
             INNER JOIN TPRAPO APO ON (APO.NUAPO = APA.NUAPO) 
         WHERE EXISTS (SELECT 1  
             FROM TPRIATV IATV  
                WHERE IATV.IDIPROC = ?  
                     AND APO.IDIATV = IATV.IDIATV  
                 )
            AND APA.CODPRODPA = ?
            AND APA.CONTROLEPA = ?
            GROUP BY CODPRODPA,CONTROLEPA
         ) APA_PERDA 
 WHERE PROD.CODPROD = IPA.CODPRODPA AND IPA.IDIPROC   = ? 
     AND IPA.CONCLUIDO = 'N' 
     AND IPA.CODPRODPA = ?
    AND IPA.CONTROLEPA = ?
    AND EXISTS ( SELECT 1 
                        FROM TPRAPA APA INNER JOIN TPRAPO APO ON(APO.NUAPO = APA.NUAPO) 
                    WHERE APA.CONTROLEPA = IPA.CONTROLEPA 
                    AND APA.CODPRODPA = IPA.CODPRODPA 
               )
    GROUP BY IPA.CODPRODPA, IPA.CONTROLEPA, PROD.DECQTD
   -- HAVING SUM (APA.QTDAPONTADA) + SUM(APA_PERDA.QTDPERDA) - SUM (IPA.QTDPRODUZIR) >= 0 
Params:
  1 = 19740
  2 = 220
  3 = 15698
  4 = 19740
  5 = 2
  6 =  
  7 = 15698
  8 = 2
  9 =  
  10 = 15698
  11 = 2
  12 =  
-------------------------------------------------------------------------------------------------------
##ID_267## tempo: 34 (ms)
/* Runtime-info
Application: OperacaoProducao
Referer: https://satis2.nuvemdatacom.com.br:8110/mgeprod/OperacaoProducao.xhtml5
ResourceID: br.com.sankhya.producao.cad.OperacaoProducao
service-name: OperacaoProducaoSP.confirmarApontamento
uri: /mgeprod/service.sbr
*/
 SELECT IPA.CODPRODPA 
        , (SELECT SUM(QTDAPONTADA + QTDPERDA)
                 FROM TPRAPO APO
                 INNER JOIN TPRAPA APA ON(APO.NUAPO = APA.NUAPO)
                 INNER JOIN TPRIATV IATV ON(IATV.IDIATV = APO.IDIATV)
                 WHERE IATV.IDEFX = ?
                 AND IATV.IDIPROC = ?) AS SOMAQTDAPONTADA
         ,PRODUTO.TIPCONTEST
         ,PRODUTO.DESCRPROD
         ,PRODUTO.VALCBGLOBAL
         ,(SELECT COUNT(*) FROM TPRSERPA SERPA
          WHERE SERPA.IDIPROC = ?
            AND SERPA.CODPRODPA = IPA.CODPRODPA) SERIESPA
          , QTDPERDA
          ,(SELECT COUNT(*) FROM TPRSERPA SERPA
          WHERE SERPA.IDIPROC = ?
            AND SERPA.CODPRODPA = IPA.CODPRODPA
            AND SERPA.PERDA = 'S') AS SERIES_PERDA
     FROM TPRIPA IPA, 
         (SELECT SUM(APA.QTDAPONTADA) AS QTDAPONTADA 
               FROM TPRAPA APA  
           WHERE EXISTS ( SELECT APO.NUAPO 
                                FROM TPRAPO APO 
                            WHERE APO.NUAPO   = APA.NUAPO 
                            AND APO.IDIATV = ? 
                       ) 
         ) APA, 
         (SELECT SUM(APA.QTDPERDA) AS QTDPERDA 
             FROM TPRAPA APA 
             INNER JOIN TPRAPO APO ON (APO.NUAPO = APA.NUAPO) 
         WHERE EXISTS (SELECT 1  
             FROM TPRIATV IATV  
                WHERE IATV.IDIPROC = ?  
                     AND APO.IDIATV = IATV.IDIATV  
                 )  
         ) APA_PERDA,
         (SELECT TIPCONTEST,DESCRPROD,VALCBGLOBAL FROM TGFPRO PRO
          INNER JOIN TPRIPA IPA  ON (IPA.CODPRODPA = PRO.CODPROD) 
          WHERE PRO.CODPROD = IPA.CODPRODPA 
          AND IPA.IDIPROC = ?) PRODUTO
 WHERE IPA.IDIPROC   = ? 
     AND IPA.CONCLUIDO = 'N'          
    GROUP BY IPA.CODPRODPA,TIPCONTEST,PRODUTO.DESCRPROD, QTDPERDA, VALCBGLOBAL
