	MAX(LMP.CODLOCALBAIXA) AS CODLOCALBAIXA
FROM TPRLMP LMP
	INNER JOIN TPREFX EFX ON(EFX.IDEFX = LMP.IDEFX)
	INNER JOIN TPRIPROC IPROC ON(IPROC.IDPROC = EFX.IDPROC)
