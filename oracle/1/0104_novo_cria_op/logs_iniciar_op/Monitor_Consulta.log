_CabecalhoNota.NUNOTA)) and ((TPRROPE.NUNOTA IS NOT NULL AND R0_CabecalhoNota.TIPMOV = 'F' AND TPRROPE.IDIATV IN (SELECT ATV.IDIATV FROM TPRIATV ATV WHERE ATV.IDIPROC = 16198))))  ORDER BY TPRROPE.NUNOTA DESC
