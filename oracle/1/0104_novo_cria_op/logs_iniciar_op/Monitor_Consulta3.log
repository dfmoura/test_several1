SELECT TPRLPA.BASCALCDTVAL AS BASCALCDTVAL,TPRLPA.CODLOCDEST AS CODLOCDEST,TPRLPA.CODPRODPA AS CODPRODPA,TPRLPA.CODUSUALT AS CODUSUALT,TPRLPA.CODUSUCAD AS CODUSUCAD,TPRLPA.CONTROLEPA AS CONTROLEPA,TPRLPA.DHALTER AS DHALTER,TPRLPA.DHCAD AS DHCAD,TPRLPA.IDFORMULA AS IDFORMULA,TPRLPA.IDPROC AS IDPROC,TPRLPA.MASCSERIE AS MASCSERIE,TPRLPA.MULTIDEAL AS MULTIDEAL,TPRLPA.QTDPRODMIN AS QTDPRODMIN,TPRLPA.TAMLOTEPAD AS TAMLOTEPAD,TPRLPA.TEMPOATRAVESS AS TEMPOATRAVESS,TPRLPA.TEMPOFIXO AS TEMPOFIXO,TPRLPA.TIPOGERASERIE AS TIPOGERASERIE,TPRLPA.TIPOTEMPO AS TIPOTEMPO,TPRLPA.UNTEMPOATRAVESS AS UNTEMPOATRAVESS, (
SELECT 
    NVL(ROUND(SUM(LMP.QTDMISTURA * NVL(CUS.CUSSEMICM, 0)),2),0) AS QTDUSO
FROM 
    TPRLMP LMP
    INNER JOIN TGFPRO PRO ON (LMP.CODPRODMP = PRO.CODPROD)
    INNER JOIN TPRATV ATV ON (ATV.IDEFX = LMP.IDEFX)
    INNER JOIN TPRPRC PRC ON (PRC.IDPROC = ATV.IDPROC)
    INNER JOIN TPRLPA LPA ON (LPA.IDPROC = PRC.IDPROC AND LPA.CODPRODPA = LMP.CODPRODPA AND NVL(LPA.CONTROLEPA, ' ') = NVL(LMP.CONTROLEPA, ' '))
    LEFT JOIN TPRPLP PLP ON (PRC.CODPLP = PLP.CODPLP)
    -- CORREÇĂO AQUI: Preparamos o custo antes do JOIN
    LEFT JOIN (
        SELECT A.CODPROD, A.CUSSEMICM
        FROM TGFCUS A
        INNER JOIN (
            SELECT CODPROD, MAX(DTATUAL) AS MAX_DT 
            FROM TGFCUS 
            GROUP BY CODPROD
        ) B ON A.CODPROD = B.CODPROD AND A.DTATUAL = B.MAX_DT
    ) CUS ON (CUS.CODPROD = PRO.CODPROD)
WHERE 
    LPA.IDPROC = TPRLPA.IDPROC
    AND (NVL(LMP.CONTROLEPA, ' ') = ' ' OR LMP.CONTROLEPA IS NULL) 
    AND LPA.CODPRODPA = TPRLPA.CODPRODPA) AS AD_CUSSEMICMPA, ( SELECT REFERENCIA FROM TGFPRO PRO WHERE CODPROD = TPRLPA.CODPRODPA) AS REFERENCIA,(/*start.VALIDAVERSAO*/ SELECT CASE WHEN COUNT(IPROC.IDPROC) > 0 THEN 'S' ELSE 'N' END AS VALIDAVERSAO
FROM TPRIPROC IPROC 
INNER JOIN TPRIPA IPA ON (IPA.IDIPROC = IPROC.IDIPROC)
INNER JOIN TGFPRO PRO ON (PRO.CODPROD = IPA.CODPRODPA)
WHERE IPROC.IDPROC = TPRLPA.IDPROC
AND IPA.CODPRODPA = TPRLPA.CODPRODPA 
AND (PRO.TIPCONTEST = 'L' OR IPA.CONTROLEPA = CASE WHEN TPRLPA.CONTROLEPA = ' ' THEN IPA.CONTROLEPA ELSE TPRLPA.CONTROLEPA END)/*end.VALIDAVERSAO*/) AS VALIDAVERSAO FROM TPRLPA /*SQL_92_JOINED_TABLES*/  WHERE (TPRLPA.IDPROC = ? AND TPRLPA.CODPRODPA = ? AND TPRLPA.CONTROLEPA = ?)
Params:
  1 = 30
  2 = 4
  3 =  
