##ID_325## tempo: 1 (ms)
/* Runtime-info
Application: OperacaoProducao
Referer: https://satis2.nuvemdatacom.com.br:8110/mgeprod/OperacaoProducao.xhtml5
ResourceID: br.com.sankhya.producao.cad.OperacaoProducao
service-name: OperacaoProducaoSP.confirmarApontamento
uri: /mgeprod/service.sbr
*/

SELECT 
X.*
FROM(
	SELECT 
	LMP.IDEFX,
	LMP.SEQMP,
	(CASE 
		WHEN LMP.TIPOCONTROLEMP = 'L' --LITERAL
			THEN LMP.CONTROLEMP
		WHEN LMP.TIPOCONTROLEMP = 'H' --HERDAR DO PA   
			THEN ?
		ELSE -- AUTOMATICO (SERÁ SEMPRE NULL)
			NULL
		END
	) AS CONTROLEMP,
	LMP.CODVOL,
	PRODMP.TIPCONTEST
	FROM TPRLMP LMP
	INNER JOIN TPRATV ATV ON(ATV.IDEFX = LMP.IDEFX)
	INNER JOIN TGFPRO PRODMP ON (PRODMP.CODPROD = LMP.CODPRODMP)
	WHERE
	LMP.CODPRODPA = ?
	AND LMP.CODPRODMP = ?
	AND	((? = 0 AND ATV.LISTAMPPADRAO = 'S') OR (? > 0 AND ATV.IDEFX = ?))
	AND (
		(LMP.CONTROLEPA IS NOT NULL AND LMP.CONTROLEPA = ?)
		OR (
			LMP.CONTROLEPA IS NULL
			AND NOT EXISTS(
				SELECT 1 
				FROM TPRLMP LMP2 
				WHERE
				LMP2.IDEFX = LMP.IDEFX
				AND LMP2.CODPRODPA = LMP.CODPRODPA
				AND LMP2.CONTROLEPA = ?
				AND LMP2.CODPRODMP = LMP.CODPRODMP
				AND LMP2.CONTROLEMP = LMP.CONTROLEMP
			)
		)
		OR (LMP.CONTROLEPA IS NOT NULL AND LMP.CONTROLEPA = ' ')
	)
) X
WHERE
((? IS NULL AND X.CONTROLEMP IS NULL)
OR 
(TIPCONTEST = 'L' OR (? IS NOT NULL AND X.CONTROLEMP = ?)))
AND X.CODVOL = ?
Params:
  1 =  
  2 = 2
  3 = 15
  4 = 220
  5 = 220
  6 = 220
  7 =  
  8 =  
  9 = null
  10 = null
  11 = null
  12 = UN
-------------------------------------------------------------------------------------------------------
