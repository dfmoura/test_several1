SELECT TMP.*
FROM (SELECT ITE.*
 		, (SELECT DIN.PERCREDBASEEFET 
 		   FROM TGFDIN DIN
   		   WHERE DIN.NUNOTA = ITE.NUNOTA
   			   AND DIN.SEQUENCIA = ITE.SEQUENCIA
   			   AND DIN.CODIMP = 1
   			   AND DIN.CODINC = 1) AS PERCREDBASEEFET
		, (SELECT DIN.ALIQUOTAEFET 
		   FROM TGFDIN DIN
       	   WHERE DIN.NUNOTA = ITE.NUNOTA
       	       AND DIN.SEQUENCIA = ITE.SEQUENCIA
       		   AND DIN.CODIMP = 1
       		   AND DIN.CODINC = 1) AS ALIQUOTAEFET
	  FROM TGFITE ITE
      WHERE ITE.NUNOTA = ?
      	  AND ITE.SEQUENCIA > 0
     	  AND (ITE.CODTRIB = 60 OR ITE.CSOSN = 500)
	) TMP
WHERE NVL(TMP.ALIQUOTAEFET, 0) > 0
Params:
  1 = 162253
-------------------------------------------------------------------------------------------------------
