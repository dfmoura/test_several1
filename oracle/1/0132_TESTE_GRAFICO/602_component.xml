        <expression type="sql" data-source="MGEDS"><![CDATA[WITH dados AS (
    SELECT 'PROJB' projeto, TO_DATE('01/2025','MM/YYYY') periodo, 100 valor FROM dual UNION ALL
    SELECT 'PROJB', TO_DATE('02/2025','MM/YYYY'), 200 FROM dual UNION ALL
    SELECT 'PROJB', TO_DATE('03/2025','MM/YYYY'), 450 FROM dual UNION ALL
    SELECT 'PROJB', TO_DATE('04/2025','MM/YYYY'), 300 FROM dual UNION ALL
    SELECT 'PROJC', TO_DATE('01/2025','MM/YYYY'), 400 FROM dual UNION ALL
    SELECT 'PROJC', TO_DATE('02/2025','MM/YYYY'), 300 FROM dual UNION ALL
    SELECT 'PROJC', TO_DATE('03/2025','MM/YYYY'), 900 FROM dual UNION ALL
    SELECT 'PROJC', TO_DATE('04/2025','MM/YYYY'), 100 FROM dual
)
SELECT 
    TO_CHAR(periodo,'MM/YYYY') periodo,
    MAX(CASE WHEN projeto = 'PROJA' THEN valor END) AS PROJA,
    MAX(CASE WHEN projeto = 'PROJB' THEN valor END) AS PROJB,
    MAX(CASE WHEN projeto = 'PROJC' THEN valor END) AS PROJC,
    MAX(CASE WHEN projeto = 'PROJD' THEN valor END) AS PROJD,
    MAX(CASE WHEN projeto = 'PROJE' THEN valor END) AS PROJE,
    MAX(CASE WHEN projeto = 'PROJF' THEN valor END) AS PROJF,
    MAX(CASE WHEN projeto = 'PROJG' THEN valor END) AS PROJG,
    MAX(CASE WHEN projeto = 'PROJH' THEN valor END) AS PROJH,
    MAX(CASE WHEN projeto = 'PROJI' THEN valor END) AS PROJI,
    MAX(CASE WHEN projeto = 'PROJJ' THEN valor END) AS PROJJ,
    MAX(CASE WHEN projeto = 'PROJK' THEN valor END) AS PROJK,
    MAX(CASE WHEN projeto = 'PROJL' THEN valor END) AS PROJL,
    MAX(CASE WHEN projeto = 'PROJM' THEN valor END) AS PROJM,
    MAX(CASE WHEN projeto = 'PROJN' THEN valor END) AS PROJN,
    MAX(CASE WHEN projeto = 'PROJO' THEN valor END) AS PROJO,
    MAX(CASE WHEN projeto = 'PROJP' THEN valor END) AS PROJP,
    MAX(CASE WHEN projeto = 'PROJQ' THEN valor END) AS PROJQ,
    MAX(CASE WHEN projeto = 'PROJR' THEN valor END) AS PROJR,
    MAX(CASE WHEN projeto = 'PROJS' THEN valor END) AS PROJS,
    MAX(CASE WHEN projeto = 'PROJT' THEN valor END) AS PROJT,
    MAX(CASE WHEN projeto = 'PROJU' THEN valor END) AS PROJU,
    MAX(CASE WHEN projeto = 'PROJV' THEN valor END) AS PROJV,
    MAX(CASE WHEN projeto = 'PROJW' THEN valor END) AS PROJW,
    MAX(CASE WHEN projeto = 'PROJX' THEN valor END) AS PROJX,
    MAX(CASE WHEN projeto = 'PROJY' THEN valor END) AS PROJY,
    MAX(CASE WHEN projeto = 'PROJZ' THEN valor END) AS PROJZ
FROM dados
GROUP BY periodo
ORDER BY periodo]]></expression>
