SELECT TGFVEN.ACRESCMAX AS ACRESCMAX,TGFVEN.AD_CODEMPEXT AS AD_CODEMPEXT,TGFVEN.AD_CODEMPEXT2 AS AD_CODEMPEXT2,TGFVEN.AD_CODPARRDV AS AD_CODPARRDV,TGFVEN.AD_COORDENADOR AS AD_COORDENADOR,TGFVEN.AD_DESLIGADO AS AD_DESLIGADO,TGFVEN.AD_DESLIGADO2 AS AD_DESLIGADO2,TGFVEN.AD_FECHAPLUS AS AD_FECHAPLUS,TGFVEN.AD_TIPO AS AD_TIPO,TGFVEN.AD_VALIDAFECHPLUS AS AD_VALIDAFECHPLUS,TGFVEN.AD_VENDEDOR_MATRIZ AS AD_VENDEDOR_MATRIZ,TGFVEN.APELIDO AS APELIDO,TGFVEN.ATIVO AS ATIVO,TGFVEN.ATUACOMPRADOR AS ATUACOMPRADOR,TGFVEN.CODCARGAHOR AS CODCARGAHOR,TGFVEN.CODCENCUSPAD AS CODCENCUSPAD,TGFVEN.CODEMP AS CODEMP,TGFVEN.CODFORM AS CODFORM,TGFVEN.CODFUNC AS CODFUNC,TGFVEN.CODGER AS CODGER,TGFVEN.CODPARC AS CODPARC,TGFVEN.CODREG AS CODREG,TGFVEN.CODUSU AS CODUSU,TGFVEN.CODVEND AS CODVEND,TGFVEN.COMCM AS COMCM,TGFVEN.COMGER AS COMGER,TGFVEN.COMVENDA AS COMVENDA,TGFVEN.DESCMAX AS DESCMAX,TGFVEN.DIACOM AS DIACOM,TGFVEN.DTALTER AS DTALTER,TGFVEN.EMAIL AS EMAIL,TGFVEN.GRUPODESCVEND AS GRUPODESCVEND,TGFVEN.GRUPORETENCAO AS GRUPORETENCAO,TGFVEN.PARTICMETA AS PARTICMETA,TGFVEN.PERCCUSVAR AS PERCCUSVAR,TGFVEN.PROVACRESC AS PROVACRESC,TGFVEN.PROVACRESCCAC AS PROVACRESCCAC,TGFVEN.RECHREXTRA AS RECHREXTRA,TGFVEN.SALDODISP AS SALDODISP,TGFVEN.SALDODISPCAC AS SALDODISPCAC,TGFVEN.SENHA AS SENHA,TGFVEN.TIPCALC AS TIPCALC,TGFVEN.TIPFECHCOM AS TIPFECHCOM,TGFVEN.TIPVALOR AS TIPVALOR,TGFVEN.TIPVEND AS TIPVEND,TGFVEN.VLRHORA AS VLRHORA, (
SELECT 
    LISTAGG(distinct NVL(cus.AD_APELIDO,CUS.DESCRCENCUS), ' || ') WITHIN GROUP (ORDER BY cus.codcencus) AS codencus_list
FROM tgfven ven
LEFT JOIN tsicus cus ON ven.codvend = cus.AD_VENDEDOR_RESP and ven.codvend = TGFVEN.CODVEND
WHERE ven.ATIVO = 'S' AND ven.CODVEND <> 0) AS AD_APELIDO_CR, (
SELECT
V.REMFIXA
FROM AD_VENDREGIAO V
WHERE V.CODCADASTRO = (SELECT MAX(C.CODCADASTRO) FROM AD_VENDREGIAO  C WHERE C.CODVEND = TGFVEN.CODVEND)
AND V.CODVEND = TGFVEN.CODVEND) AS AD_REMFIXA, (

SELECT 
    (SELECT F_DESCROPC('AD_VENDREGIAO', 'TIPREPRESEN', REG.TIPREPRESEN) FROM DUAL) AS TIPO
FROM AD_VENDREGIAO REG
INNER JOIN TGFVEN VEN ON VEN.CODVEND = REG.CODVEND
WHERE REG.CODCADASTRO = (SELECT MAX(C.CODCADASTRO) FROM AD_VENDREGIAO  C WHERE C.CODVEND = TGFVEN.CODVEND)
AND REG.CODCADASTRO = (SELECT MAX(CODCADASTRO) FROM AD_VENDREGIAO)
AND VEN.CODVEND=TGFVEN.CODVEND) AS AD_TIPOREP FROM TGFVEN /*SQL_92_JOINED_TABLES*/  WHERE (TGFVEN.CODVEND = ?)
Params:
  1 = 0
-------------------------------------------------------------------------------------------------------
