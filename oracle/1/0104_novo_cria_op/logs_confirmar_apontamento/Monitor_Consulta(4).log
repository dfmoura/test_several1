SELECT 
SUM(ITE.QTDNEG - ITE.QTDENTREGUE) AS SALDO_RESERVA
FROM TGFITE ITE
INNER JOIN TGFCAB C ON(C.NUNOTA = ITE.NUNOTA)
INNER JOIN TGFTOP T ON(T.CODTIPOPER = C.CODTIPOPER AND T.DHALTER = C.DHTIPOPER)
WHERE
ITE.CODPROD = ?
AND ITE.PENDENTE = 'S'
AND (? = '*' OR ITE.CONTROLE = ?)
AND T.ATUALEST = 'R'
AND C.TIPMOV <> 'F'
AND ITE.NUNOTA IN(
   SELECT 
   DISTINCT R.NUNOTA
   FROM TPRROPE R
   INNER JOIN TPRIATV IATV ON(IATV.IDIATV = R.IDIATV)
   WHERE
   IATV.IDIPROC = ?
)
