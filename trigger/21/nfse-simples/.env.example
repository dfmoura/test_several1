# Ambiente: homolog | prod
NFSE_AMBIENTE=homolog

# Dados da empresa (CNPJ deve ser igual ao certificado)
NFSE_CNPJ=53369941000163
NFSE_C_MUN_EMISSOR=3170206
NFSE_INSCRICAO_MUNICIPAL=12345678
NFSE_RAZAO_SOCIAL=Sua Empresa LTDA
NFSE_DPS_SERIE=00001

# Certificado A1 e-CNPJ (caminhos dentro do container — não altere)
NFSE_CERT_PATH=/run/secrets/certificado.pfx
NFSE_CERT_PASSWORD_FILE=/run/secrets/certificado.senha
NFSE_CERT_REQUIRED=true

# Gov.br — false para conectar ao ambiente real
NFSE_GOV_MOCK=false

# Acesso ao painel
NFSE_WEB_PASSWORD=admin
NFSE_SESSION_SECRET=buc110t@2026diogo

# Porta no seu computador (18210 evita conflito com 8080, 3000 e o sistema antigo)
NFSE_PORT=18210

# Sincronização automática de notas recebidas (segundos)
NFSE_SYNC_INTERVAL_SEC=300

# Pasta de dados — definida automaticamente no Docker (/app/data)
# NFSE_DATA_DIR=/app/data
