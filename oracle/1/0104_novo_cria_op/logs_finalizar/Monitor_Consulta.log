SELECT TPRIPROC.AD_DTFABRICACAO AS AD_DTFABRICACAO,TPRIPROC.AD_LOTEPI AS AD_LOTEPI,TPRIPROC.AD_OBSERVACAO AS AD_OBSERVACAO,TPRIPROC.AD_QUALIDADE AS AD_QUALIDADE,TPRIPROC.CODPARC AS CODPARC,TPRIPROC.CODPLP AS CODPLP,TPRIPROC.CODUSUFINAL AS CODUSUFINAL,TPRIPROC.CODUSUINC AS CODUSUINC,TPRIPROC.DHINC AS DHINC,TPRIPROC.DHINST AS DHINST,TPRIPROC.DHTERMINO AS DHTERMINO,TPRIPROC.DTINICIOMAX AS DTINICIOMAX,TPRIPROC.DTPREVENT AS DTPREVENT,TPRIPROC.IDICOP AS IDICOP,TPRIPROC.IDIPROC AS IDIPROC,TPRIPROC.IDIPROCPAI AS IDIPROCPAI,TPRIPROC.IDPROC AS IDPROC,TPRIPROC.IDWFLOW AS IDWFLOW,TPRIPROC.NROLOTE AS NROLOTE,TPRIPROC.NUMPS AS NUMPS,TPRIPROC.NUNOTA AS NUNOTA,TPRIPROC.PRIORIDADE AS PRIORIDADE,TPRIPROC.SEQNOTA AS SEQNOTA,TPRIPROC.STATUSPROC AS STATUSPROC,TPRIPROC.TEMPOATRAVESS AS TEMPOATRAVESS, ( select sum(estoque-reservado) 
from tgfest 
where CONTROLE =  TPRIPROC.NROLOTE 
AND CODPROD IN (SELECT CODPRODPA FROM TPRIPA WHERE IDIPROC = TPRIPROC.IDIPROC) 
AND CODEMP = TPRIPROC.CODPLP) AS AD_ESTOQUE, ( select idiprocpi from TPRIDEP where idiprocpa = TPRIPROC.IDIPROC) AS AD_IDIPROCPI, (
SELECT
LISTAGG(RAM.NURAM, ', ')
FROM TPRIPA PA
LEFT JOIN TGFRAM RAM ON RAM.CODPROD = PA.CODPRODPA AND RAM.CONTROLE = PA.NROLOTE
WHERE PA.IDIPROC = TPRIPROC.IDIPROC) AS AD_NURAM, (CASE WHEN TPRIPROC.CODPARCTERC IS NULL THEN (SELECT CODPARCTERC FROM TPRTXAT TXAT WHERE TXAT.IDIPROC = TPRIPROC.IDIPROC AND IDEFX = 0) ELSE TPRIPROC.CODPARCTERC END) AS CODPARCTERC FROM TPRIPROC /*SQL_92_JOINED_TABLES*/  WHERE (TPRIPROC.IDIPROC = ?)
Params:
  1 = 16230
