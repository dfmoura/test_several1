##ID_151## tempo: 2 (ms)
/* Runtime-info
Application: OrdensProducao
Referer: https://satis2.nuvemdatacom.com.br:8110/mgeprod/OrdensProducao.xhtml5
ResourceID: br.com.sankhya.prod.OrdensProducaoHTML
entity: CabecalhoInstanciaProcesso
service-name: DatasetSP.loadRecords
uri: /mge/service.sbr
*/
SELECT 
X.*
FROM( 
	SELECT
	    
		IPA.CODPRODPA,
	 	IPA.NROLOTE,
		IPA.CONTROLEPA,
		(SELECT SUM(QTDPRODUZIR) FROM TPRIPA IPA WHERE IPA.IDIPROC = ?) AS QTDPRODUZIR,
		PRO.COMPLDESC,
		PRO.CODVOL,
		PRO.CODGRUPOPROD,
		PRO.DESCRPROD,
		MPS.DTINICMPS,
		MPS.DTFINMPS,
		PRO.DECQTD,
		PRO.REFERENCIA,
		GRU.DESCRGRUPOPROD,
		IPROC.PRIORIDADE  AS PRIORIDADE,
		(SELECT COUNT(1) FROM TPRIPA IPA3 WHERE IPA3.IDIPROC = IPA.IDIPROC) AS QTDPRODUTOS,
		(CASE WHEN IPA.NROLOTE <> 'CURINGA' THEN 1 ELSE 2 END) AS ORDER_NROLOTE
	FROM
		TPRIPA IPA INNER JOIN TGFPRO PRO ON(IPA.CODPRODPA = PRO.CODPROD)
		INNER JOIN TPRIPROC IPROC ON(IPROC.IDIPROC = IPA.IDIPROC)
		INNER JOIN TGFGRU GRU ON(PRO.CODGRUPOPROD = GRU.CODGRUPOPROD)
		LEFT JOIN TPRMPS MPS ON (MPS.NUMPS = IPROC.NUMPS)
	WHERE
		IPA.IDIPROC = ?
	ORDER BY IPA.CODPRODPA, ORDER_NROLOTE, IPA.CONTROLEPA

) X
WHERE ROWNUM < 2

Params:
  1 = 16201
  2 = 16201
-------------------------------------------------------------------------------------------------------
##ID_152## tempo: 1 (ms)
/* Runtime-info
Application: OrdensProducao
Referer: https://satis2.nuvemdatacom.com.br:8110/mgeprod/OrdensProducao.xhtml5
ResourceID: br.com.sankhya.prod.OrdensProducaoHTML
entity: CabecalhoInstanciaProcesso
service-name: DatasetSP.loadRecords
uri: /mge/service.sbr
*/
 SELECT 
X.*
FROM( 
	SELECT
	    
		EFX.DESCRICAO,
		IATV.CODEXEC,
		USU.NOMEUSU
	FROM
		TPRIATV IATV
		INNER JOIN TPREFX EFX ON(EFX.IDEFX = IATV.IDEFX)
		LEFT JOIN TSIUSU USU ON(USU.CODUSU = IATV.CODEXEC) 
	WHERE
		IATV.IDIPROC = ?
	ORDER BY IATV.IDIATV DESC

) X
WHERE ROWNUM < 2

Params:
  1 = 16201
