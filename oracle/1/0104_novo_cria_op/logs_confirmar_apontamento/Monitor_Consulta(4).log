    TPRLMP LMP,
    TGFCUS CUS
WHERE 
    LMP.CODPRODPA = TPRLMP.CODPRODPA
    AND LMP.IDEFX= TPRLMP.IDEFX
    AND LMP.CODPRODMP = TPRLMP.CODPRODMP 
    AND LMP.CODPRODMP = CUS.CODPROD AND CUS.DTATUAL= (SELECT MAX(DTATUAL) FROM TGFCUS CUS2 WHERE CUS.CODPROD = CUS2.CODPROD)) AS AD_CUSMEDSEMICM_UNT, (  
(QTDMISTURA / (select nvl(AD_DENSIDADE,1) from tgfpro where codprod = TPRLMP.codprodpa))*100) AS AD_PART_QTDMISTURAMP, ( SELECT REFERENCIA FROM TGFPRO PRO WHERE CODPROD = TPRLMP.CODPRODMP) AS REFERENCIA FROM TPRLMP /*SQL_92_JOINED_TABLES*/  WHERE (TPRLMP.IDEFX = ? AND TPRLMP.SEQMP = ?)
