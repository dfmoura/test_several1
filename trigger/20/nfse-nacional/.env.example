# Ambiente: dev | homolog | prod
NFSE_AMBIENTE=dev

# Prestador (único CNPJ) — município emissor e inscrição municipal somente daqui (manual);
# CNPJ e razão social vêm do certificado A1 quando ativo (não do cartão CNPJ)
NFSE_CNPJ=53369941000163
NFSE_C_MUN_EMISSOR=3170206
NFSE_DPS_SERIE=00001
NFSE_RAZAO_SOCIAL=Empresa Exemplo LTDA
# Inscrição municipal do prestador — cadastro municipal; não existe na Receita Federal
NFSE_INSCRICAO_MUNICIPAL=12345678

# Certificado A1 (e-CNPJ ICP-Brasil)
NFSE_CERT_PATH=/run/secrets/certificado.pfx
NFSE_CERT_PASSWORD=change-me
# Preferível em Docker: senha em arquivo (não aparece em docker inspect)
NFSE_CERT_PASSWORD_FILE=/run/secrets/certificado.senha
# Exige certificado real mesmo com gov mock (assinatura XML real em dev)
NFSE_CERT_REQUIRED=false

# API interna
NFSE_API_KEY=dev-api-key-change-in-production
NFSE_API_PORT=3000
NFSE_JWT_SECRET=dev-jwt-secret-change-in-production

# Portas no host (evitam conflito com 3000, 8080, 5432, etc.)
NFSE_HOST_PORT_API=18100
NFSE_HOST_PORT_DANFSE=18101
NFSE_HOST_PORT_TRAEFIK=18180
NFSE_HOST_PORT_TRAEFIK_DASHBOARD=18181
NFSE_HOST_PORT_POSTGRES=15432
NFSE_HOST_PORT_REDIS=16379
NFSE_HOST_PORT_RABBITMQ_UI=18672
NFSE_HOST_PORT_MINIO_CONSOLE=19001
NFSE_HOST_PORT_GRAFANA=18200
NFSE_HOST_PORT_PROMETHEUS=19090
NFSE_HOST_PORT_WEB=18102

# Console web (painel administrativo)
NFSE_WEB_PASSWORD=admin
NFSE_WEB_SESSION_SECRET=dev-session-secret-change-in-production

# Banco de dados (portas do host — ver NFSE_HOST_PORT_* acima)
DATABASE_URL=postgresql://nfse:nfse@localhost:15432/nfse

# Redis
REDIS_URL=redis://localhost:16379

# RabbitMQ
RABBITMQ_URL=amqp://nfse:nfse@localhost:5672

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=nfse
MINIO_SECRET_KEY=nfse-secret-key
MINIO_BUCKET=nfse-xml
MINIO_USE_SSL=false

# Sync ADN
NFSE_SYNC_INTERVAL_SEC=300

# Observabilidade
LOG_LEVEL=info

# Gov.br mock (dev only)
NFSE_GOV_MOCK=true

# Enriquecimento cadastral (CNPJ Receita Federal + IBGE)
NFSE_CADASTRO_ENABLED=true
NFSE_CADASTRO_CACHE_TTL_SEC=86400
