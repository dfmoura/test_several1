<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="sub_filhos" language="groovy" pageWidth="802" pageHeight="555" orientation="Landscape" columnWidth="802" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
    <parameter name="P_NUATV" class="java.math.BigDecimal"/>

    <queryString>
        <![CDATA[
SELECT
    CAST(1 AS NUMBER) AS NUATV_PAI,
    CAST(2 AS NUMBER) AS NUATV_FILHO,
    '2 - Revisao da Capa do Backlog Requisitos' AS TITULO_FILHO
FROM DUAL
UNION ALL
SELECT
    CAST(1 AS NUMBER) AS NUATV_PAI,
    CAST(3 AS NUMBER) AS NUATV_FILHO,
    '3 - Ajuste Final da Capa do Backlog' AS TITULO_FILHO
FROM DUAL
        ]]>
    </queryString>

    <field name="NUATV_PAI" class="java.math.BigDecimal"/>
    <field name="NUATV_FILHO" class="java.math.BigDecimal"/>
    <field name="TITULO_FILHO" class="java.lang.String"/>
    <filterExpression><![CDATA[$P{P_NUATV} != null && $F{NUATV_PAI}.compareTo($P{P_NUATV}) == 0]]></filterExpression>

    <columnHeader>
        <band height="17">
            <staticText>
                <reportElement x="0" y="1" width="130" height="15"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="6" isBold="true"/></textElement>
                <text><![CDATA[ID Atividade Filho]]></text>
            </staticText>
            <staticText>
                <reportElement x="130" y="1" width="672" height="15"/>
                <textElement verticalAlignment="Middle"><font size="6" isBold="true"/></textElement>
                <text><![CDATA[Título Filho]]></text>
            </staticText>
            <line><reportElement x="0" y="16" width="802" height="1"/></line>
        </band>
    </columnHeader>

    <detail>
        <band height="13">
            <textField>
                <reportElement x="0" y="1" width="130" height="12"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="6"/></textElement>
                <textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{NUATV_FILHO}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="130" y="1" width="672" height="12"/>
                <textElement verticalAlignment="Middle"><font size="6"/></textElement>
                <textFieldExpression class="java.lang.String"><![CDATA[$F{TITULO_FILHO}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
</jasperReport>
