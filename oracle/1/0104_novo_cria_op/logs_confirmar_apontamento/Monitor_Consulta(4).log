##ID_125## tempo: 19 (ms)
/* Runtime-info
Application: OperacaoProducao
Referer: https://satis2.nuvemdatacom.com.br:8110/mgeprod/OperacaoProducao.xhtml5
ResourceID: br.com.sankhya.producao.cad.OperacaoProducao
service-name: OperacaoProducaoSP.criarApontamento
uri: /mgeprod/service.sbr
*/
SELECT DISTINCT X.CODPRODMPALT, 
                X.QTD_SUB, 
                X.QTDMISTURA, 
                X.QTD, 
                X.CONJUNTO, 
                X.CONTROLEMPALT, 
                X.CODVOL,
                X.ORDEM,
                X.CODLOCALORIG,
                X.CODLOCALBAIXA
FROM   (SELECT DISTINCT MPA.CODPRODMPALT, 
                        IMPA.QTDMISTURA / MPA.QTDMISTURA AS QTD_SUB, 
                        IMPA.QTDMISTURA, 
                        MPA.QTDMISTURA AS QTD, 
                        MPA.CONJUNTO, 
                        MPA.CONTROLEMPALT, 
                        MPA.CODVOL, 
                        IMPA.ORDEM ,
                        MPA.CODLOCALORIG,
                        MPA.CODLOCALBAIXA
        FROM   TPRMPA MPA 
               INNER JOIN TPRIMPA IMPA 
                       ON ( MPA.CODPRODPA = IMPA.CODPRODPA 
                       		AND (NVL(MPA.CONTROLEPA, ' ') = ' ' OR MPA.CONTROLEPA = IMPA.CONTROLEPA)
                            AND MPA.CODPRODMP = IMPA.CODPRODMP 
                            AND (NVL(MPA.CONTROLEMP, ' ') = ' ' OR MPA.CONTROLEMP = IMPA.CONTROLEMP) 
                            AND MPA.CODPRODMPALT = IMPA.CODPRODMPALT 
                            AND MPA.CONTROLEMPALT = IMPA.CONTROLEMPALT )
				INNER JOIN TPRATV ATV
						ON ( ATV.IDEFX = MPA.IDEFX )
				INNER JOIN TPREFX EFX 
						ON ( EFX.IDEFX = MPA.IDEFX )
				INNER JOIN TPRPRC PRC
						ON ( PRC.IDPROC = EFX.IDPROC )
				INNER JOIN TPRIPROC IPROC
						ON ( IPROC.IDPROC = PRC.IDPROC AND IPROC.IDIPROC = ?) 
        WHERE  MPA.CODPRODMP = ? 
               AND (NVL(MPA.CONTROLEMP, ' ') = ' ' OR MPA.CONTROLEMP = ?) 
               AND MPA.CODPRODPA = ? 
               AND (NVL(MPA.CONTROLEPA, ' ') = ' ' OR MPA.CONTROLEPA = ?)
               AND IMPA.IDIPROC = ?) X 
ORDER  BY X.ORDEM
