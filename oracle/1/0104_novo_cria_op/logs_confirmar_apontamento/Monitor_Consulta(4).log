service-name: OperacaoProducaoSP.confirmarApontamento
uri: /mgeprod/service.sbr
*/
SELECT *
FROM TGFITE JOIN TGFPRO ON (TGFITE.CODPROD = TGFPRO.CODPROD)
WHERE TGFITE.NUNOTA IN (
  SELECT CAB.NUNOTA 
  FROM TPRROPE ROPE JOIN TGFCAB CAB ON (ROPE.NUNOTA = CAB.NUNOTA)
  WHERE ROPE.NUNOTA IS NOT NULL
  AND CAB.TIPMOV <> 'F'
  AND ROPE.IDIATV IN (
    SELECT IATV.IDIATV
    FROM TPRIATV IATV
    WHERE IATV.IDIPROC = ?)
) 
AND SEQUENCIA > 0
AND TIPCONTEST = 'L'
AND RESERVA = 'S'
AND CONTROLE <> ' '
