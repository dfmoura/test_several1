# HTTPS automático (Let's Encrypt) + proxy para o app.
# Variável DOMAIN: ex. licitacoes.osbrasiluberlandia.org
{$DOMAIN:localhost} {
	encode gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}
	reverse_proxy app:8096
}
