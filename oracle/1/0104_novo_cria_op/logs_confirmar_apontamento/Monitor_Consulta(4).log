ResourceID: br.com.sankhya.producao.cad.OperacaoProducao
service-name: OperacaoProducaoSP.confirmarApontamento
uri: /mgeprod/service.sbr
*/

SELECT
	APA.CODPRODPA,
	APA.CONTROLEPA,
    APA.NUAPO,
    APA.SEQAPA,
	APA.QTDAPONTADA,
	APA.QTDPERDA,
	APA.QTDFAT,
	APO.DHAPO,
	IATV.IDEFX,
	(SELECT SUM(NVL(MER.QTD,0) + NVL(MER.QTDPERDA,0)) AS QTD  
   FROM TPRMER MER 
  WHERE MER.CODPRODPA = APA.CODPRODPA	
    AND MER.CONTROLEPA = APA.CONTROLEPA	
    AND MER.IDIATV = IATV.IDIATV  	
    AND MER.IDIPROC = IATV.IDIPROC  	
    AND MER.SINAL = 1  	
    AND MER.STATUSEXEC = 'N') AS QTDREPOSITORIO
FROM TPRAPA APA
INNER JOIN TPRAPO APO ON(APO.NUAPO = APA.NUAPO)
INNER JOIN TPRIATV IATV ON(IATV.IDIATV = APO.IDIATV)
WHERE APA.CODPRODPA = ?
AND APA.CONTROLEPA = ?
AND IATV.IDIPROC = ?
AND APA.QTDAPONTADA > APA.QTDFAT
AND APO.SITUACAO <> 'P'
