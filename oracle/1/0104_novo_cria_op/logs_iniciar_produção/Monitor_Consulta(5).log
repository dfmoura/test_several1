 SELECT ITR.CODREGRA,ITR.CODINSTPRINC, REG.TIPO FROM TGFITR ITR   INNER JOIN TGFREG REG ON (REG.CODREGRA = ITR.CODREGRA)   INNER JOIN TGFCER CER ON (CER.CODREGRA = REG.CODREGRA) WHERE   CER.TIPO = 'U'    AND CER.ATIVO = 'S'    AND ITR.ATIVO = 'S'    AND CER.CHAVE = ?    AND TRANSLATE(UPPER(REG.INSTPRINC),'ÁÉÍÓÚĂŐÂĘÎÔŰŔČĚŇŮÇ','AEIOUAOAEIOUAEIOUC') = ?   AND CER.FILTRAR = 'S'    AND (REG.INSTSEC IS NULL OR REG.INSTSEC = '')  ORDER BY ITR.CODREGRA,ITR.SEQUENCIA
