##ID_347## tempo: 8 (ms)
SELECT TPREIATV.CODEXEC AS CODEXEC,TPREIATV.CODMTP AS CODMTP,TPREIATV.CODUSU AS CODUSU,TPREIATV.DHFINAL AS DHFINAL,TPREIATV.DHINICIO AS DHINICIO,TPREIATV.IDEIATV AS IDEIATV,TPREIATV.IDIATV AS IDIATV,TPREIATV.OBSERVACAO AS OBSERVACAO,TPREIATV.TIPO AS TIPO , MotivosParada.DESCRICAO AS l0_DESCRICAO,MotivosParada.DESCRICAO AS l0_DESCRICAO,Usuario.NOMEUSU AS l1_NOMEUSU,Usuario2.NOMEUSU AS l2_NOMEUSU FROM TPREIATV  left join (SELECT DESCRICAO,CODMTP FROM TPRMTP) MotivosParada  ON(TPREIATV.CODMTP = MotivosParada.CODMTP) left join (SELECT CODUSU,NOMEUSU FROM TSIUSU) Usuario  ON(TPREIATV.CODEXEC = Usuario.CODUSU) left join (SELECT CODUSU,NOMEUSU FROM TSIUSU) Usuario2  ON(TPREIATV.CODUSU = Usuario2.CODUSU)   WHERE (((1<>1)))  ORDER BY TPREIATV.DHINICIO,TPREIATV.DHFINAL
