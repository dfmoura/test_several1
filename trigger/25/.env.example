# Application
APP_NAME=whatsapp-ai-agent
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# Security
WEBHOOK_SECRET=change-me-webhook-secret
RATE_LIMIT_PER_MINUTE=30

# AI Provider: openai | ollama
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://host.docker.internal:11434
MODEL_NAME=gpt-4o-mini
AI_MAX_TOKENS=500
AI_TEMPERATURE=0.7

# Database
DATABASE_URL=postgresql+asyncpg://agent:agent@postgres:5432/whatsapp_agent
DATABASE_URL_SYNC=postgresql://agent:agent@postgres:5432/whatsapp_agent

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_CONTEXT_TTL=86400

# Evolution API
EVOLUTION_URL=http://evolution:8080
EVOLUTION_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=personal
EVOLUTION_WEBHOOK_PATH=/webhook/evolution

# Owner identity (agent impersonates this person)
OWNER_NAME=Diego
OWNER_PHONE=5511999999999
