SELECT 
	MAX(LMP.CODLOCALBAIXA) AS CODLOCALBAIXA
FROM TPRLMP LMP
	INNER JOIN TPREFX EFX ON(EFX.IDEFX = LMP.IDEFX)
	INNER JOIN TPRIPROC IPROC ON(IPROC.IDPROC = EFX.IDPROC)
WHERE
	LMP.CODLOCALBAIXA > 0
AND IPROC.IDIPROC = ?
AND LMP.CODPRODMP = ?
AND LMP.CODPRODPA = ?
AND (NVL(LMP.CONTROLEPA, ' ') = ? OR (NVL(LMP.CONTROLEPA, ' ') = ' '))


