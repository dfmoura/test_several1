SELECT
	RNG.NURNG,
	DESCRICAO,
	CODUSULIB,
	TIPOEXPRESSAO,
    EXPRESSAO,
    CONFIG,
	EVENTO
FROM
    TGFRNG RNG
    INNER JOIN TGFTRN TRN ON (TRN.NURNG = RNG.NURNG)
WHERE
	RNG.ATIVO = 'S' AND
    RNG.ONDE = ? AND
    RNG.QUANDO = ? AND
    TRN.CODTIPOPER = ?
ORDER BY
	TRN.SEQEXEC,
    RNG.NURNG
