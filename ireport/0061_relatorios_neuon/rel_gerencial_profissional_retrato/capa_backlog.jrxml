            <textField><reportElement x="110" y="312" width="392" height="14"/><textElement><font size="8"/></textElement><textFieldExpression class="java.lang.String"><![CDATA[$F{SOLICITANTE}]]></textFieldExpression></textField>
            <staticText><reportElement x="14" y="332" width="95" height="14"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[Área Cliente]]></text></staticText>
            <textField><reportElement x="110" y="332" width="392" height="14"/><textElement><font size="8"/></textElement><textFieldExpression class="java.lang.String"><![CDATA[$F{AREA_CLIENTE}]]></textFieldExpression></textField>

            <staticText>
                <reportElement x="0" y="360" width="515" height="16">
                    <printWhenExpression><![CDATA["S".equalsIgnoreCase($P{P_APRES_ESTIM})]]></printWhenExpression>
                </reportElement>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Estimativas]]></text>
            </staticText>
