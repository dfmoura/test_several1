            <staticText><reportElement x="14" y="252" width="95" height="14"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[Tipo / Negócio]]></text></staticText>
            <textField><reportElement x="110" y="252" width="392" height="14"/><textElement><font size="8"/></textElement><textFieldExpression class="java.lang.String"><![CDATA[$F{TIPO_ATIVIDADE} + " | " + $F{NEGOCIO}]]></textFieldExpression></textField>

