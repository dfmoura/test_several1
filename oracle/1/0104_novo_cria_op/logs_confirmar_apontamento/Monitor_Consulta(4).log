service-name: OperacaoProducaoSP.confirmarApontamento
uri: /mgeprod/service.sbr
*/
SELECT IPA.CODPRODPA
		, IPA.CONTROLEPA
		, SUM(APA_PERDA.QTDPERDA) AS QTDPERDA
	   	, SUM (APA.QTDAPONTADA) + SUM(APA_PERDA.QTDPERDA) - SUM (IPA.QTDPRODUZIR) AS TOTAL_APONTADO , MAX(SEQAPA) AS SEQAPA
 	FROM TPRIPA IPA,
		 (SELECT APA.CODPRODPA, APA.CONTROLEPA,SUM(APA.QTDAPONTADA) AS QTDAPONTADA , MAX(SEQAPA) AS SEQAPA
 		  	FROM TPRAPA APA
 		  WHERE APA.NUAPO IN (
 		  						SELECT APO.NUAPO FROM TPRAPO APO 
 		  						WHERE APO.IDIATV IN (SELECT IATV.IDIATV FROM TPRIATV IATV WHERE IATV.IDIPROC = ? 
 		  						AND IATV.IDEFX = (SELECT IATV2.IDEFX FROM TPRIATV IATV2 WHERE IATV2.IDIATV = ?))
 		  					)
		 GROUP BY CODPRODPA,CONTROLEPA
		 ) APA,
		 (SELECT APA.CODPRODPA, APA.CONTROLEPA, SUM(APA.QTDPERDA) AS QTDPERDA 
  			FROM TPRAPA APA  
  			WHERE APA.NUAPO IN (	SELECT APO.NUAPO FROM TPRAPO APO 
  									WHERE APO.IDIATV IN (SELECT IATV.IDIATV FROM TPRIATV IATV WHERE IATV.IDIPROC = ?)
  								)
            GROUP BY CODPRODPA,CONTROLEPA
	   	) APA_PERDA 
 WHERE IPA.IDIPROC   = ?
 	AND IPA.CONCLUIDO = 'N'
 	AND APA.CODPRODPA = IPA.CODPRODPA
    AND APA.CONTROLEPA = IPA.CONTROLEPA
    AND APA_PERDA.CODPRODPA = IPA.CODPRODPA
    AND APA_PERDA.CONTROLEPA = IPA.CONTROLEPA
	AND EXISTS ( SELECT 1
			   	 	FROM TPRAPA APA INNER JOIN TPRAPO APO ON(APO.NUAPO = APA.NUAPO)
			   	 WHERE APA.CONTROLEPA = IPA.CONTROLEPA
					AND APA.CODPRODPA = APA.CODPRODPA
					AND APA.NUAPO = ?
			   )
	GROUP BY IPA.CODPRODPA, IPA.CONTROLEPA
	--HAVING SUM (APA.QTDAPONTADA) + SUM(APA_PERDA.QTDPERDA) - SUM (IPA.QTDPRODUZIR) < 0
