##ID_60## tempo: 47 (ms)
/* Runtime-info
Application: OrdensProducao
Referer: https://satis2.nuvemdatacom.com.br:8110/mgeprod/OrdensProducao.xhtml5
ResourceID: br.com.sankhya.prod.OrdensProducaoHTML
entity: CabecalhoInstanciaProcesso
service-name: DatasetSP.loadRecord
uri: /mge/service.sbr
*/
SELECT 
	NVL(SUM(X.TAMLOTE), 0) AS QTD,
	NVL(SUM(X.TAMLOTE), 0) - NVL(SUM(QTD_NOTA), 0) AS SALDO_OP,
	NVL(SUM(QTD_RESERVADA), 0) AS QTD_RESERVADA,
	NVL(SUM(QTD_SUBTRAIR), 0) AS QTD_SUBTRAIR
FROM (
	SELECT 
	LOTE.IDIPROC,
	NVL(SUM(LOTE.TAMLOTE), 0) AS TAMLOTE,
	NVL(SUM(NOTA.QTDNEG), 0) AS QTD_NOTA,
   (CASE
         WHEN NVL(SUM(NOTA.QTDNEG), 0) > 0 THEN APO_PERDA.QTDPERDA
         ELSE 0
         END)      AS QTD_PERDA,
   (CASE
         WHEN NVL(SUM(NOTA.QTDNEG), 0) > NVL(MAX(IDEP.QTDDEP), 0) THEN NVL(SUM(NOTA.QTDNEG), 0)
         ELSE NVL(MAX(IDEP.QTDDEP), 0)
   END) AS QTD_SUBTRAIR,
   NVL(MAX(IDEP.QTDDEP), 0) AS QTD_RESERVADA 
FROM (
	SELECT IPROC.IDIPROC AS IDIPROC,
		SUM(IPA.QTDPRODUZIR) AS TAMLOTE,
		IPA.CODPRODPA AS CODPRODPA,
		IPA.CONTROLEPA AS CONTROLEPA
	FROM
		TPRIPA IPA
	INNER JOIN TPRIPROC IPROC ON (IPA.IDIPROC = IPROC.IDIPROC)
	WHERE IPA.CODPRODPA = ?
		AND IPROC.STATUSPROC IN ('A', 'R', 'P2', 'S', 'S2')
		AND IPROC.IDIPROC = ?
		
		
	GROUP BY IPROC.IDIPROC,
		IPA.CODPRODPA,
		IPA.CONTROLEPA
) LOTE
--join com notas
LEFT JOIN (
	SELECT IDIPROC, SUM(ITE.QTDNEG) AS QTDNEG, ITE.CODPROD, ITE.CONTROLE, ROPE.CONTROLEPA
	FROM TGFCAB CAB INNER JOIN TGFITE ITE ON (ITE.NUNOTA = CAB.NUNOTA)
					INNER JOIN TPRROPE ROPE ON (ROPE.NUNOTA = CAB.NUNOTA)
					INNER JOIN TPROEST OEST ON (OEST.IDEFX = ROPE.IDEFX AND OEST.SEQOPER = ROPE.SEQOPER)
	WHERE CAB.IDIPROC IS NOT NULL 
		AND OEST.TIPOITENS = 'PA'
		AND OEST.QUANDO = 'PA'
		AND CAB.TIPMOV = 'F'
		AND ITE.USOPROD = 'V'
	GROUP BY IDIPROC, ITE.CODPROD, ITE.CONTROLE, ROPE.CONTROLEPA
) NOTA ON (
NOTA.IDIPROC = LOTE.IDIPROC
AND NOTA.CODPROD = LOTE.CODPRODPA

AND (NVL(NOTA.CONTROLEPA, ' ') = ' ' OR (NVL(NOTA.CONTROLEPA, ' ') = NVL(LOTE.CONTROLEPA, ' ')))
)
--join com perdas
LEFT JOIN (
	SELECT NVL(SUM(APA.QTDPERDA), 0) AS QTDPERDA, IATV.IDIPROC, APA.CODPRODPA, APA.CONTROLEPA
    FROM TPRAPA APA
    	INNER JOIN TPRAPO APO ON (APO.NUAPO = APA.NUAPO)
    	INNER JOIN TPRIATV IATV ON (IATV.IDIATV = APO.IDIATV)
    WHERE APO.SITUACAO = 'C'
    	AND APA.QTDPERDA > 0
    	GROUP BY IATV.IDIPROC, APA.CODPRODPA, APA.CONTROLEPA
) APO_PERDA ON (APO_PERDA.IDIPROC = LOTE.IDIPROC AND APO_PERDA.CODPRODPA = LOTE.CODPRODPA AND (NVL(APO_PERDA.CONTROLEPA, ' ') = ' ' OR (NVL(APO_PERDA.CONTROLEPA, ' ') = NVL(LOTE.CONTROLEPA, ' '))))
--join com ops dependentes
LEFT JOIN (
	SELECT IDIPROCPI, SUM(QTDDEP) AS QTDDEP FROM TPRIDEP
	GROUP BY IDIPROCPI
) IDEP ON LOTE.IDIPROC = IDEP.IDIPROCPI

    WHERE LOTE.IDIPROC = ?

