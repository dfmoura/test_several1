            <textField><reportElement x="530" y="200" width="272" height="14"/><textElement><font size="8"/></textElement><textFieldExpression class="java.lang.String"><![CDATA[$F{AREA_CLIENTE}]]></textFieldExpression></textField>

            <staticText>
