# Servidor
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Mock: true = não chama instituição; útil para desenvolvimento sem certificados/mTLS
MOCK_OPEN_FINANCE=true

# OAuth2 (client credentials — instituição; em produção costuma-se usar também fluxo com consentimento do usuário)
OF_TOKEN_URL=https://mtls.example-bank.openfinance.com.br/oauth/token
OF_CLIENT_ID=
OF_CLIENT_SECRET=
OF_SCOPE=loans

# API de Empréstimos (base URL da instituição — ajuste conforme o participante)
OF_API_BASE_URL=https://mtls.example-bank.openfinance.com.br
# Caminho do recurso (ex.: lista de contratos/linhas vinculadas ao consentimento)
OF_LOANS_RESOURCE_PATH=/open-banking/loans/v1/contracts

# Timeout HTTP (ms)
OF_HTTP_TIMEOUT_MS=30000
