SELECT TPRASP.CODPRODSP AS CODPRODSP,TPRASP.CODVOL AS CODVOL,TPRASP.CONTROLESP AS CONTROLESP,TPRASP.NUAPO AS NUAPO,TPRASP.QTD AS QTD,TPRASP.SEQAPA AS SEQAPA, ( SELECT REFERENCIA FROM TGFPRO PRO WHERE CODPROD = TPRASP.CODPRODSP) AS REFERENCIA , Produto.DESCRPROD AS l0_DESCRPROD,Produto.DECQTD AS l0_DECQTD,Produto.TIPCONTEST AS l0_TIPCONTEST,Produto.TITCONTEST AS l0_TITCONTEST,Produto.LISCONTEST AS l0_LISCONTEST,Volume.DESCRVOL AS l1_DESCRVOL,Volume.DESCRVOL AS l1_DESCRVOL FROM TPRASP  left join (SELECT TIPCONTEST,TITCONTEST,DESCRPROD,DECQTD,CODPROD,LISCONTEST FROM TGFPRO) Produto  ON(TPRASP.CODPRODSP = Produto.CODPROD) left join (SELECT DESCRVOL,CODVOL FROM TGFVOL) Volume  ON(TPRASP.CODVOL = Volume.CODVOL)   WHERE (( (TPRASP.NUAPO = ?)  AND  (TPRASP.SEQAPA = ?) )) 
