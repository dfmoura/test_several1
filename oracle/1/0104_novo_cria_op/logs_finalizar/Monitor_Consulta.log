SELECT DISTINCT IDEP.IDIPROCPA, IDEP.IDIPROCPI, CASE WHEN IPROC_PI.STATUSPROC = 'F' THEN 'S' ELSE 'N' END AS PIFINALIZADO
FROM TPRIDEP IDEP
  JOIN TPRIPROC IPROC_PI ON (IDEP.IDIPROCPI = IPROC_PI.IDIPROC)
  JOIN TPRIPROC IPROC_PA ON (IDEP.IDIPROCPA = IPROC_PA.IDIPROC)
  JOIN (
		SELECT 
        LPI1.IDPROC
        ,LPI1.CODPRODPI
        ,LPI1.CONTROLEPI
        ,LPI1.CODPRODPA
        ,LPI1.CONTROLEPA
        ,LPI1.AGUARDARSUBOP
        FROM TPRLPI LPI1
        UNION 
        SELECT
        LPI2.IDPROC
        ,IMPA.CODPRODMPALT AS CODPRODPI
        ,IMPA.CONTROLEMPALT AS CONTROLEPI
        ,LPI2.CODPRODPA
        ,LPI2.CONTROLEPA
        ,LPI2.AGUARDARSUBOP
        FROM TPRLPI LPI2
        INNER JOIN TPRIMPA IMPA ON (LPI2.CODPRODPA = IMPA.CODPRODPA 
                                    AND NVL(LPI2.CONTROLEPA, ' ') = NVL(IMPA.CONTROLEPA, ' ')
                                    AND LPI2.CODPRODPI = IMPA.CODPRODMP
                                    AND NVL(LPI2.CONTROLEPI, ' ') = NVL(IMPA.CONTROLEMP, ' '))
  ) LPI ON (LPI.IDPROC = IPROC_PA.IDPROC AND LPI.CODPRODPI = IDEP.CODPRODPI AND LPI.CONTROLEPI = IDEP.CONTROLEPI AND LPI.CODPRODPA = IDEP.CODPRODPA AND LPI.CONTROLEPA = IDEP.CONTROLEPA) 
WHERE IPROC_PA.STATUSPROC = 'R'
  AND LPI.AGUARDARSUBOP = 'S'
  AND IDEP.IDIPROCPA IN (SELECT IDIPROCPA FROM TPRIDEP WHERE IDIPROCPI = ?)
ORDER BY IDEP.IDIPROCPA ASC
