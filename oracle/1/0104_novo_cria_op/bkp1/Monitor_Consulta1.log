SELECT DISTINCT X.CODPRODMPALT, 
                X.QTD_SUB, 
                X.QTDMISTURA, 
                X.QTD, 
                X.CONJUNTO, 
                X.CONTROLEMPALT, 
                X.CODVOL,
                X.ORDEM,
                X.CODLOCALORIG,
                X.CODLOCALBAIXA
FROM   (SELECT DISTINCT MPA.CODPRODMPALT, 
