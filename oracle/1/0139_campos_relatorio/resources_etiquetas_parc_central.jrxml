<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="template_etiquetas" pageWidth="283" pageHeight="227" columnWidth="283" leftMargin="0" rightMargin="0" topMargin="6" bottomMargin="3">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="12"/>
	<property name="ireport.definition"/>
	<parameter name="NUNOTA" class="java.math.BigDecimal"/>
	<queryString>
		<![CDATA[SELECT *
FROM (
    SELECT
        CAB.NUNOTA,
        CAB.NUMNOTA,
        PAR.NOMEPARC,
        CAB.QTDVOL,
        CAB.NUMNOTA AS CODIGOBARRAS,

        EMP.RAZAOSOCIAL AS EMP_RAZAOSOCIAL,

        ENDER.NOMEEND,
        PAR.NUMEND,
        PAR.COMPLEMENTO,
        BAI.NOMEBAI,
        CID.NOMECID,
        CID.UF,

        TRANS.NOMEPARC AS TRANS_NOMEPARC,

        REV.IDREV,
        SEP.CODAREASEP,


        CASE WHEN SEP.CODAREASEP = 3 THEN TO_CHAR(ITE.CODPROD) END AS CODPROD_EXIBIR,
        CASE WHEN SEP.CODAREASEP = 3 THEN PRO.DESCRPROD END AS DESCRPROD_EXIBIR,
        CASE WHEN SEP.CODAREASEP = 3 THEN PRO.COMPLDESC END AS COMPLDESC_EXIBIR

    FROM TGFCAB CAB

    LEFT JOIN TGFPAR PAR ON PAR.CODPARC = CAB.CODPARC
    LEFT JOIN TSIEND ENDER ON ENDER.CODEND = PAR.CODEND
    LEFT JOIN TSIBAI BAI ON BAI.CODBAI = PAR.CODBAI
    LEFT JOIN TSICID CID ON CID.CODCID = PAR.CODCID

    LEFT JOIN TSIEMP EMP ON EMP.CODEMP = CAB.CODEMP
    LEFT JOIN TGFPAR TRANS ON TRANS.CODPARC = CAB.CODPARCTRANSP

    LEFT JOIN TGWREV REV ON REV.NUNOTA = CAB.NUNOTA
    LEFT JOIN TGWSEP SEP ON SEP.NUSEPARACAO = REV.NUSEPARACAO


    LEFT JOIN TGFITE ITE
        ON ITE.NUNOTA = REV.NUNOTA
       AND ITE.SEQUENCIA = REV.SEQUENCIA

    LEFT JOIN TGFPRO PRO
        ON PRO.CODPROD = ITE.CODPROD

    WHERE CAB.NUNOTA = $P{NUNOTA}


    ORDER BY
        CASE WHEN SEP.CODAREASEP = 3 THEN 0 ELSE 1 END,
        REV.SEQUENCIA
)
WHERE ROWNUM = 1]]>
	</queryString>
