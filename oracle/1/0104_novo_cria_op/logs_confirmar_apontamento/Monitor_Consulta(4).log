SELECT 
SUM ( PRC.VALOR )

FROM TCSPRE PRC
INNER JOIN TCSCON CON ON PRC.NUMCONTRATO=CON.NUMCONTRATO


WHERE CON.NUMCONTRATO=TCSCON.NUMCONTRATO
AND CON.CODPARC=TCSCON.CODPARC) AS AD_VLRTOT, ( SELECT MAX(PSC.CODPROD) FROM TCSCON CON, TCSPSC PSC WHERE CON.NUMCONTRATO = PSC.NUMCONTRATO AND CON.NUMCONTRATO = TCSCON.NUMCONTRATO) AS CODPROD, ( SELECT NVL(E.NOMEEND,'') AS ENDERECO FROM TGFPAR P, TSIEND E WHERE P.CODEND = E.CODEND AND P.CODPARC = (SELECT C.CODPARC FROM TCSCON C WHERE C.NUMCONTRATO = TCSCON.NUMCONTRATO)) AS ENDERECO, ( SELECT (NVL(P.IDENTINSCESTAD,'')) AS INSCEST FROM TGFPAR P WHERE P.CODPARC = (SELECT C.CODPARC FROM TCSCON C WHERE C.NUMCONTRATO = TCSCON.NUMCONTRATO)) AS INSCEST, ( SELECT (NVL(P.NOMEPARC,'')) AS INSCEST FROM TGFPAR P WHERE P.CODPARC = (SELECT C.CODPARC FROM TCSCON C WHERE C.NUMCONTRATO = TCSCON.NUMCONTRATO)) AS NOMEPARC, ( SELECT MAX(PSC.QTDEPREVISTA) FROM TCSCON CON, TCSPSC PSC WHERE CON.NUMCONTRATO = PSC.NUMCONTRATO AND CON.NUMCONTRATO = TCSCON.NUMCONTRATO) AS QTDEPREVISTA, ( SELECT (CASE WHEN NVL(CON.UNICONVSC, 0) = 0 THEN 0 ELSE CON.QTDNEG * (CON.VALNEGSC / CON.UNICONVSC) END) FROM TCSCON CON WHERE CON.NUMCONTRATO = TCSCON.NUMCONTRATO AND CON.TIPOARM = 'A' AND CON.MODALIDADE = 'C') AS TOTNEG FROM TCSCON /*SQL_92_JOINED_TABLES*/  WHERE (TCSCON.NUMCONTRATO = ?)
