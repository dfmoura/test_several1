SELECT IPA.CODPRODPA
        , IPA.CONTROLEPA
        , SUM(APA_PERDA.QTDPERDA) AS QTDPERDA
FROM TPRIPA IPA,
     (SELECT SUM(APA.QTDPERDA) AS QTDPERDA 
      FROM TPRAPA APA  
      INNER JOIN TPRAPO APO ON (APO.NUAPO = APA.NUAPO)
      WHERE EXISTS (SELECT 1 
                           FROM TPRIATV IATV
                           WHERE IATV.IDIPROC = ?
                           AND APO.IDIATV = IATV.IDIATV
                        )
       ) APA_PERDA 
WHERE IPA.IDIPROC   = ?
    AND EXISTS (SELECT 1
                FROM TPRAPA APA INNER JOIN TPRAPO APO ON(APO.NUAPO = APA.NUAPO)
                WHERE APA.CONTROLEPA = IPA.CONTROLEPA
                AND APA.CODPRODPA = IPA.CODPRODPA
           )
GROUP BY IPA.CODPRODPA, IPA.CONTROLEPA
HAVING SUM(APA_PERDA.QTDPERDA) > 0
