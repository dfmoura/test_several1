<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="capa_backlog" language="groovy" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <property name="ireport.zoom" value="1.0"/>
    <property name="ireport.x" value="0"/>
    <property name="ireport.y" value="0"/>

    <parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
        <defaultValueExpression><![CDATA[""]]></defaultValueExpression>
    </parameter>
    <parameter name="P_APRES_APONT" class="java.lang.String">
        <parameterDescription><![CDATA[Apresentar Apontamentos? (S/N)]]></parameterDescription>
        <defaultValueExpression><![CDATA["N"]]></defaultValueExpression>
    </parameter>
    <parameter name="P_APRES_COMENT" class="java.lang.String">
        <parameterDescription><![CDATA[Apresentar Comentários? (S/N)]]></parameterDescription>
        <defaultValueExpression><![CDATA["N"]]></defaultValueExpression>
    </parameter>
    <parameter name="P_APRES_ESTIM" class="java.lang.String">
        <parameterDescription><![CDATA[Apresentar Estimativa? (S/N)]]></parameterDescription>
        <defaultValueExpression><![CDATA["N"]]></defaultValueExpression>
    </parameter>
    <parameter name="P_APRES_PAIFILHO" class="java.lang.String">
        <parameterDescription><![CDATA[Apresentar ID Pai/Filho? (S/N)]]></parameterDescription>
        <defaultValueExpression><![CDATA["N"]]></defaultValueExpression>
    </parameter>

    <queryString>
        <![CDATA[
SELECT
    CAST(1 AS NUMBER) AS NUATV,
    CAST(NULL AS NUMBER) AS NUATVORIG,
    '1 - Impressao da Capa do Backlog Requisitos' AS TITULO_ATV,
    '11:30' AS ESTIMATIVA,
    TO_DATE('2026-04-15','YYYY-MM-DD') AS DTSOL,
    'Estruturacao da impressao da capa com informacoes executivas do backlog.' AS DESCRICAO,
    '1001 - ACME Industria' AS CLIENTE,
    '3001 - Implantacao ERP Fase 2' AS PROJETO,
    '10 - Evolucao de Requisitos' AS TIPO_ATIVIDADE,
    'N - NEUON' AS NEGOCIO,
    '501 - Maria Alves' AS SOLICITANTE,
    '12 - Operacoes' AS AREA_CLIENTE
FROM DUAL
UNION ALL
SELECT
    CAST(2 AS NUMBER) AS NUATV,
    CAST(1 AS NUMBER) AS NUATVORIG,
    '2 - Revisao da Capa do Backlog Requisitos' AS TITULO_ATV,
    '05:00' AS ESTIMATIVA,
    TO_DATE('2026-04-20','YYYY-MM-DD') AS DTSOL,
    'Ajustes finais de layout e padronizacao visual da capa para diretoria.' AS DESCRICAO,
    '1002 - Beta Logistica' AS CLIENTE,
    '3002 - Sustentacao Integracoes' AS PROJETO,
    '20 - Melhoria Continua' AS TIPO_ATIVIDADE,
    'M - MITRA' AS NEGOCIO,
    '502 - Joao Pereira' AS SOLICITANTE,
    '21 - TI Corporativa' AS AREA_CLIENTE
FROM DUAL
UNION ALL
SELECT
    CAST(3 AS NUMBER) AS NUATV,
    CAST(1 AS NUMBER) AS NUATVORIG,
    '3 - Ajuste Final da Capa do Backlog' AS TITULO_ATV,
    '02:30' AS ESTIMATIVA,
    TO_DATE('2026-04-22','YYYY-MM-DD') AS DTSOL,
    'Ajustes de fechamento para o layout final da capa.' AS DESCRICAO,
    '1002 - Beta Logistica' AS CLIENTE,
    '3002 - Sustentacao Integracoes' AS PROJETO,
    '20 - Melhoria Continua' AS TIPO_ATIVIDADE,
    'M - MITRA' AS NEGOCIO,
    '502 - Joao Pereira' AS SOLICITANTE,
    '21 - TI Corporativa' AS AREA_CLIENTE
FROM DUAL
        ]]>
    </queryString>

    <field name="NUATV" class="java.math.BigDecimal"/>
    <field name="NUATVORIG" class="java.math.BigDecimal"/>
