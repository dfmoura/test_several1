SELECT TPRAPA.CODMPE AS CODMPE,TPRAPA.CODPRODPA AS CODPRODPA,TPRAPA.CONTROLEPA AS CONTROLEPA,TPRAPA.NUAPO AS NUAPO,TPRAPA.QTDAPONTADA AS QTDAPONTADA,TPRAPA.QTDFAT AS QTDFAT,TPRAPA.QTDFATSP AS QTDFATSP,TPRAPA.QTDMPE AS QTDMPE,TPRAPA.QTDPERDA AS QTDPERDA,TPRAPA.SEQAPA AS SEQAPA, ( SELECT REFERENCIA FROM TGFPRO PRO WHERE CODPROD = TPRAPA.CODPRODPA) AS REFERENCIA FROM TPRAPA /*SQL_92_JOINED_TABLES*/   WHERE (TPRAPA.NUAPO = ?) 
Params:
