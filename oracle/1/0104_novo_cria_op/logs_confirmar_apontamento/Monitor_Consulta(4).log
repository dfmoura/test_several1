                       FROM TGMTME TME 
                       WHERE TME.CODTIPOPER = ?) 
       OR CFG.CODMETA = ?)
  AND CFG.PRODUTO = 0 
  AND CFG.CONTROLE = 0 
  AND CFG.GRUPO = 0 
  AND CFG.LOCAL = 0 
  AND CFG.MARCA = 0
ORDER BY CFG.CODMETA

