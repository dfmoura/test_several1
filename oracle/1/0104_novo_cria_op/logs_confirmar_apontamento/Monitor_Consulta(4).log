                                                   	FROM TPRLPI LPI
                                                     WHERE LPI.IDPROC      = IPROC.IDPROC
	                                                 	AND LPI.CODPRODPA   = ?
	                                                 	AND (LPI.CONTROLEPA = ? OR CONTROLEPA = ' ')
	                                                  	AND LPI.CODPRODPI   = AMP.CODPRODMP
	                                                  	AND (LPI.CONTROLEPI = AMP.CONTROLEMP OR LPI.CONTROLEPI <> ' ') 
                                                  )
