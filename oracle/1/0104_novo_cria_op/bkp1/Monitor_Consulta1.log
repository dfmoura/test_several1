SELECT 
 PRC.PADRAO,
 PRC.IDPROC, 
 PRC.CODPRC, 
 PRC.DESCRABREV, 
 PRO.CODPROD,
 PRO.DESCRPROD, 
 PRC.MULTIPA, 
 PRC.MULTICONTROLE, 
 PRO.COMPLDESC, 
 LPA.CONTROLEPA, 
 LPA.TAMLOTEPAD, 
 LPA.MULTIDEAL, 
 LPA.QTDPRODMIN,
 PRC.CODPLP, 
 PRC.TIPONROLOTE,
 PRC.TIPOINICIA,
 PRC.USATERCEIRO,
 PRC.DEFTERCEIRO, 
 PRC.PROCDESMONTE,
 PRC.ATIVO,
 PRC.VERSAO
 
FROM 
 TPRPRC PRC
 INNER JOIN TPRLPA LPA ON PRC.IDPROC = LPA.IDPROC
 INNER JOIN TGFPRO PRO ON LPA.CODPRODPA = PRO.CODPROD
WHERE 
  LPA.CODPRODPA = ?
 AND PRC.TIPOPROC = 'M'
 AND (? IS NULL OR (
   ('S' = NVL(PRC.PADRAOPRODUTO, 'N') AND 'S' = NVL(PRC.PADRAO, 'N')) OR
   ('S' = NVL(PRC.PADRAOPRODUTO, 'N') AND 'N' = NVL(PRC.PADRAO, 'N')) OR
   ('N' = NVL(PRC.PADRAOPRODUTO, 'N') AND 'S' = NVL(PRC.PADRAO, 'N')))
 )  
 AND (LPA.CONTROLEPA = ' ' OR LPA.CONTROLEPA = ?)
 AND (? IS NULL OR PRC.CODPLP IS NULL OR PRC.CODPLP = ?)
 AND (? IS NULL OR PRC.IDPROC = ?)
 AND (? IS NULL OR PRC.PROCDESMONTE = ?)
 AND (NVL(PRC.PROCREPARO, 'N') = ?)
 AND (? IS NULL OR PRC.EXIGEPEDIDO <> 'N')
 AND ((? IS NULL AND PRC.PRODPARATERCEIRO IN ('N', 'O')) OR (? IS NOT NULL AND PRC.PRODPARATERCEIRO <> 'N'))
 AND PRC.VERSAO = (SELECT MAX(PRC2.VERSAO) FROM TPRPRC PRC2 WHERE PRC2.CODPRC = PRC.CODPRC  AND PRC2.ATIVO = 'S' )
ORDER BY PRC.PADRAOPRODUTO DESC, PRC.PADRAO DESC, LPA.CONTROLEPA DESC, PRC.IDPROC DESC
