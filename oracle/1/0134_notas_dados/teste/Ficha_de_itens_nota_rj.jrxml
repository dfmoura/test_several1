<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Ficha_de_itens_nota_rj" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="10" bottomMargin="45">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="ireport.definition"/>
	<parameter name="NUNOTA" class="java.math.BigDecimal" isForPrompting="false">
		<defaultValueExpression><![CDATA[new BigDecimal(188383)]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT PRO.DESCRPROD AS PRODUTO,
       ITE.VLRUNIT AS  VLRUNIT,
       ITE.VLRTOT AS VLRTOTAL,
       ITE.QTDNEG AS VOLUME
 FROM TGFITE ITE
  LEFT JOIN TGFPRO PRO ON ITE.CODPROD = PRO.CODPROD
   WHERE ITE.NUNOTA = $P{NUNOTA}]]>
	</queryString>
	<field name="PRODUTO" class="java.lang.String">
		<fieldDescription><![CDATA[Produto]]></fieldDescription>
	</field>
	<field name="VLRUNIT" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[Valor uit]]></fieldDescription>
	</field>
	<field name="VLRTOTAL" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[Total]]></fieldDescription>
	</field>
	<field name="VOLUME" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[Volume]]></fieldDescription>
	</field>
