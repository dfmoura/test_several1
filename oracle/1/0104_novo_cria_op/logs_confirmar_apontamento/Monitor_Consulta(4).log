COMGER,TGFITE.PERCDESC AS PERCDESC,TGFITE.PERCDESCBASE AS PERCDESCBASE,TGFITE.PERCDESCBONIF AS PERCDESCBONIF,TGFITE.PERCDESCDIGITADO AS PERCDESCDIGITADO,TGFITE.PERCDESCFORNECEDOR AS PERCDESCFORNECEDOR,TGFITE.PERCDESCPROM AS PERCDESCPROM,TGFITE.PERCDESCTGFDES AS PERCDESCTGFDES,TGFITE.PERCGERMIN AS PERCGERMIN,TGFITE.PERCPUREZA AS PERCPUREZA,TGFITE.PERCREDVLRIPI AS PERCREDVLRIPI,TGFITE.PERCSTFCPINTANT AS PERCSTFCPINTANT,TGFITE.PERCUSAQUDECPE AS PERCUSAQUDECPE,TGFITE.PERCUSAQUDECPEEST AS PERCUSAQUDECPEEST,TGFITE.PRECOBASE AS PRECOBASE,TGFITE.PRECOBASEQTD AS PRECOBASEQTD,TGFITE.PRODUTONFE AS PRODUTONFE,TGFITE.PRODUTOPESQUISADO AS PRODUTOPESQUISADO,TGFITE.QTDCONFERIDA AS QTDCONFERIDA,TGFITE.QTDENTREGUE AS QTDENTREGUE,TGFITE.QTDFAT AS QTDFAT,TGFITE.QTDFIXADA AS QTDFIXADA,TGFITE.QTDFORMULA AS QTDFORMULA,TGFITE.QTDNEG AS QTDNEG,TGFITE.QTDPECA AS QTDPECA,TGFITE.QTDTRIBEXPORT AS QTDTRIBEXPORT,TGFITE.QTDVOL AS QTDVOL,TGFITE.QTDWMS AS QTDWMS,TGFITE.REDBASEST AS REDBASEST,TGFITE.RESERVA AS RESERVA,TGFITE.SEQPEDIDO2 AS SEQPEDIDO2,TGFITE.SEQUENCIA AS SEQUENCIA,TGFITE.SEQUENCIAFISCAL AS SEQUENCIAFISCAL,TGFITE.SOLCOMPRA AS SOLCOMPRA,TGFITE.STATUSLOTE AS STATUSLOTE,TGFITE.STATUSNOTA AS STATUSNOTA,TGFITE.TERCEIROS AS TERCEIROS,TGFITE.TIPENTREGA AS TIPENTREGA,TGFITE.TIPOSEPARACAO AS TIPOSEPARACAO,TGFITE.TIPUTILCOM AS TIPUTILCOM,TGFITE.UNIDADE AS UNIDADE,TGFITE.USOPROD AS USOPROD,TGFITE.VARIACAOFCP AS VARIACAOFCP,TGFITE.VITEM_IBSCBS AS VITEM_IBSCBS,TGFITE.VLRACRESCDESC AS VLRACRESCDESC,TGFITE.VLRCOM AS VLRCOM,TGFITE.VLRCOMGER AS VLRCOMGER,TGFITE.VLRCREDPRES AS VLRCREDPRES,TGFITE.VLRCUS AS VLRCUS,TGFITE.VLRCUSAQUDECPE AS VLRCUSAQUDECPE,TGFITE.VLRDESC AS VLRDESC,TGFITE.VLRDESCBONIF AS VLRDESCBONIF,TGFITE.VLRDESCDIGITADO AS VLRDESCDIGITADO,TGFITE.VLRDESCMOE AS VLRDESCMOE,TGFITE.VLRDESCPARCERIA AS VLRDESCPARCERIA,TGFITE.VLRFETHAB AS VLRFETHAB,TGFITE.VLRFUNTTEL AS VLRFUNTTEL,TGFITE.VLRFUST AS VLRFUST,TGFITE.VLRICMS AS VLRICMS,TGFITE.VLRICMSANT AS VLRICMSANT,TGFITE.VLRICMSAT AS VLRICMSAT,TGFITE.VLRICMSDIFERIDO AS VLRICMSDIFERIDO,TGFITE.VLRICMSUFDEST AS VLRICMSUFDEST,TGFITE.VLRIPI AS VLRIPI,TGFITE.VLRISS AS VLRISS,TGFITE.VLRLIQPROM AS VLRLIQPROM,TGFITE.VLROUTROITEM AS VLROUTROITEM,TGFITE.VLRPROMO AS VLRPROMO,TGFITE.VLRPTOPUREZA AS VLRPTOPUREZA,TGFITE.VLRREPRED AS VLRREPRED,TGFITE.VLRREPREDSEMDESC AS VLRREPREDSEMDESC,TGFITE.VLRREPREDST AS VLRREPREDST,TGFITE.VLRRETENCAO AS VLRRETENCAO,TGFITE.VLRSTEXTRANOTA AS VLRSTEXTRANOTA,TGFITE.VLRSTFCPINTANT AS VLRSTFCPINTANT,TGFITE.VLRSUBST AS VLRSUBST,TGFITE.VLRSUBSTANT AS VLRSUBSTANT,TGFITE.VLRSUBSTUNITORIG AS VLRSUBSTUNITORIG,TGFITE.VLRTOT AS VLRTOT,TGFITE.VLRTOTMOE AS VLRTOTMOE,TGFITE.VLRTROCA AS VLRTROCA,TGFITE.VLRUNIT AS VLRUNIT,TGFITE.VLRUNITDOLAR AS VLRUNITDOLAR,TGFITE.VLRUNITLOC AS VLRUNITLOC,TGFITE.VLRUNITMOE AS VLRUNITMOE,TGFITE.VLRVENDAPROMO AS VLRVENDAPROMO, (
(
SELECT
    CASE
        WHEN CAB.TIPMOV NOT IN ('P','V') THEN ' '
        ELSE
            RTRIM(
                XMLAGG(
                    XMLELEMENT(E, TEXTO)
                    ORDER BY ORDEM
                ).EXTRACT('//text()'),
                ' '
            )
    END
FROM (
    SELECT
        ITE.NUNOTA,
        ITE.SEQUENCIA,
        1 ORDEM,
        'Desc ' || TO_CHAR(ROUND(NVL(ITE.DESC_APLICADO,0) * 100, 1)) TEXTO
    FROM VGF_DESCTAB_SATIS ITE

    UNION ALL
    SELECT
        ITE.NUNOTA,
        ITE.SEQUENCIA,
        2,
        ' por cento Desc Max ' ||
        TO_CHAR(ROUND((NVL(ITE.DESC_COMER,0) + NVL(ITE.DESC_ANTE,0)) * 100, 2))
    FROM VGF_DESCTAB_SATIS ITE

    UNION ALL
    SELECT
        ITE.NUNOTA,
        ITE.SEQUENCIA,
        3,
        ' por cento ' ||
        TO_CHAR(ROUND(NVL(ITE.DESC_ANTE,0) * 100, 2)) ||
        ' desc antecipado '
    FROM VGF_DESCTAB_SATIS ITE

    UNION ALL
    SELECT
        ITE.NUNOTA,
        ITE.SEQUENCIA,
        4,
        TO_CHAR(ROUND(NVL(ITE.DESC_COMER,0) * 100, 2)) ||
        ' desc comercial'
    FROM VGF_DESCTAB_SATIS ITE
) X
JOIN TGFCAB CAB
  ON CAB.NUNOTA = X.NUNOTA
WHERE X.NUNOTA    = TGFITE.NUNOTA
  AND X.SEQUENCIA = TGFITE.SEQUENCIA
GROUP BY
    CAB.TIPMOV,
    X.NUNOTA,
    X.SEQUENCIA
)) AS AD_PERCDESCTAB, (
SELECT  NVL(ROUND( TGFITE.QTDNEG/VOA.QUANTIDADE,2),0) AS QTDPAL 
FROM TGFVOA VOA 
WHERE VOA.CODPROD = TGFITE.CODPROD
AND VOA.CODVOL='PL') AS AD_QTDPAL, ( 
CAST(
CAST(NVL(TGFITE.QTDNEG, 0) AS DECIMAL(38, 9)) - 
CAST(NVL(TGFITE.QTDENTREGUE, 0) AS DECIMAL(38, 9)) -
CAST(NVL(TGFITE.QTDCONFERIDA, 0) AS DECIMAL(38, 9))

AS FLOAT
)) AS AD_QTDPEND_PARCIAL, (
SELECT 
CASE WHEN (TOP.ATUALFIN=0)  AND TOP.CODTIPOPER <> 1112 THEN 0
WHEN TOP.ATUALFIN=-1 THEN SUM(ITE.QTDNEG * PRO.AD_QTDVOLLT)*-1
ELSE SUM(ITE.QTDNEG * PRO.AD_QTDVOLLT) END AS VOLUME
FROM TGFITE ITE, TGFPRO PRO, TGFTOP TOP, TGFCAB CAB
WHERE ITE.CODPROD=PRO.CODPROD
AND ITE.NUNOTA=TGFITE.NUNOTA
AND CAB.CODTIPOPER=TOP.CODTIPOPER
AND CAB.DHTIPOPER=TOP.DHALTER
AND CAB.NUNOTA=ITE.NUNOTA
AND ITE.SEQUENCIA=TGFITE.SEQUENCIA
GROUP BY TOP.ATUALFIN,  TOP.CODTIPOPER, TOP.ATUALEST) AS AD_QTDVLOLT, (
SELECT CASE WHEN (TOP.ATUALFIN=0 )  AND TOP.CODTIPOPER <> 1112 THEN 0
WHEN TOP.ATUALFIN=-1 THEN (ITE.VLRTOT-ITE.VLRDESC-ITE.VLRREPRED)*-1
ELSE (ITE.VLRTOT-ITE.VLRDESC-ITE.VLRREPRED) END AS VALORFIN
FROM TGFCAB CAB, TGFTOP TOP, TGFITE ITE
WHERE CAB.CODTIPOPER=TOP.CODTIPOPER
AND CAB.DHTIPOPER=TOP.DHALTER
AND CAB.NUNOTA=ITE.NUNOTA
AND ITE.NUNOTA=TGFITE.NUNOTA
AND ITE.SEQUENCIA=TGFITE.SEQUENCIA) AS AD_VLRFIN, ( SELECT ITE.CODLOCALORIG FROM TGFITE ITE WHERE ITE.NUNOTA = TGFITE.NUNOTA AND ITE.SEQUENCIA < 0 AND ITE.SEQUENCIA = (TGFITE.SEQUENCIA * -1)) AS CODLOCALDEST, ( SELECT ITE.CONTROLE FROM TGFITE ITE WHERE ITE.NUNOTA = TGFITE.NUNOTA AND ITE.SEQUENCIA < 0 AND ITE.SEQUENCIA = (TGFITE.SEQUENCIA*-1)) AS CONTROLEDEST, ( CAST(CAST(NVL(TGFITE.QTDNEG, 0) AS DECIMAL(38, 9)) - CAST(NVL(TGFITE.QTDENTREGUE, 0) AS DECIMAL(38, 9)) AS FLOAT)) AS QTDPENDENTE, ( TGFITE.QTDNEG) AS QTDUNIDPAD, ( TGFITE.QTDNEG - TGFITE.QTDENTREGUE) AS RESERVADO, ( SELECT (CASE
           WHEN CAB.TIPMOV IN ('O', 'C', 'E')
              THEN (CASE WHEN NVL((SELECT LOGICO FROM TSIPAR WHERE CHAVE = 'DESCARRVLIQ'), 'N') = 'S' THEN (TGFITE.VLRUNIT * TGFITE.QTDNEG) ELSE TGFITE.VLRTOT END) - TGFITE.VLRDESC - TGFITE.VLRREPRED
           ELSE (CASE
                    WHEN NVL((SELECT INTEIRO
                                 FROM TSIPAR
                                WHERE CHAVE = 'TIPTABPRECOS'), 0) <> 9
                       THEN (CASE WHEN NVL((SELECT LOGICO FROM TSIPAR WHERE CHAVE = 'DESCARRVLIQ'), 'N') = 'S' THEN (TGFITE.VLRUNIT * TGFITE.QTDNEG) ELSE TGFITE.VLRTOT END) - TGFITE.VLRDESC - TGFITE.VLRREPRED
                    WHEN NVL((SELECT LOGICO
                            FROM TSIPAR
                           WHERE CHAVE = 'ADIMPVLRTOTLIQ'), 'S') <> 'S'
                       THEN (CASE WHEN NVL((SELECT LOGICO FROM TSIPAR WHERE CHAVE = 'DESCARRVLIQ'), 'N') = 'S' THEN (TGFITE.VLRUNIT * TGFITE.QTDNEG) ELSE TGFITE.VLRTOT END) - TGFITE.VLRDESC - TGFITE.VLRREPRED
                    ELSE   ((CASE WHEN NVL((SELECT LOGICO FROM TSIPAR WHERE CHAVE = 'DESCARRVLIQ'), 'N') = 'S' THEN (TGFITE.VLRUNIT * TGFITE.QTDNEG) ELSE TGFITE.VLRTOT END) - TGFITE.VLRDESC - TGFITE.VLRREPRED
                           )
                         + TGFITE.VLRSUBST
                         + ((CASE
                                WHEN TGFITE.VLRIPI > 0
                                AND NVL((SELECT SOMARIPI
                                            FROM TGFTOP TP
                                           WHERE TP.CODTIPOPER =
                                                                CAB.CODTIPOPER
                                             AND TP.DHALTER = CAB.DHTIPOPER),
                                         'N'
                                        ) <> 'N'
                                   THEN TGFITE.VLRIPI
                                ELSE 0
                             END
                            )
                           )
                 END
                )
        END
       )
  FROM TGFCAB CAB
 WHERE CAB.NUNOTA = TGFITE.NUNOTA) AS VLRTOTLIQ, ( SELECT (CASE WHEN CAB.TIPMOV IN('O','C','E') THEN TGFITE.VLRTOTMOE - TGFITE.VLRDESCMOE - TGFITE.VLRREPRED ELSE (CASE WHEN NVL((SELECT INTEIRO FROM TSIPAR WHERE CHAVE = 'TIPTABPRECO'),0) <> 9 THEN TGFITE.VLRTOTMOE - TGFITE.VLRDESCMOE - TGFITE.VLRREPRED ELSE (TGFITE.VLRTOTMOE - TGFITE.VLRDESCMOE - TGFITE.VLRREPRED) + TGFITE.VLRSUBST + ((CASE WHEN TGFITE.VLRIPI > 0 AND NVL((SELECT SOMARIPI FROM TGFTOP TP WHERE TP.CODTIPOPER = CAB.CODTIPOPER AND TP.DHALTER = CAB.DHTIPOPER),'N') <> 'N' THEN TGFITE.VLRIPI ELSE 0 END)) END) END) FROM TGFCAB CAB WHERE CAB.NUNOTA = TGFITE.NUNOTA) AS VLRTOTLIQMOE, ( TGFITE.VLRUNIT) AS VLRUNIDPAD, ( SELECT (CASE WHEN TGFITE.QTDNEG = 0 THEN 0 ELSE (CASE WHEN CAB.TIPMOV IN('O','C','E') THEN (CASE WHEN NVL((SELECT LOGICO FROM TSIPAR WHERE CHAVE = 'DESCARRVLIQ'), 'N') = 'S' THEN (TGFITE.VLRUNIT * TGFITE.QTDNEG) ELSE TGFITE.VLRTOT END) - TGFITE.VLRDESC - TGFITE.VLRREPRED ELSE (CASE WHEN NVL((SELECT INTEIRO FROM TSIPAR WHERE CHAVE = 'TIPTABPRECO'),0) <> 9 THEN (CASE WHEN NVL((SELECT LOGICO FROM TSIPAR WHERE CHAVE = 'DESCARRVLIQ'), 'N') = 'S' THEN (TGFITE.VLRUNIT * TGFITE.QTDNEG) ELSE TGFITE.VLRTOT END) - TGFITE.VLRDESC - TGFITE.VLRREPRED ELSE ((CASE WHEN NVL((SELECT LOGICO FROM TSIPAR WHERE CHAVE = 'DESCARRVLIQ'), 'N') = 'S' THEN (TGFITE.VLRUNIT * TGFITE.QTDNEG) ELSE TGFITE.VLRTOT END) - TGFITE.VLRDESC - TGFITE.VLRREPRED) + TGFITE.VLRSUBST + ((CASE WHEN TGFITE.VLRIPI > 0 AND NVL((SELECT SOMARIPI FROM TGFTOP TP WHERE TP.CODTIPOPER = CAB.CODTIPOPER AND TP.DHALTER = CAB.DHTIPOPER),'N') <> 'N' THEN TGFITE.VLRIPI ELSE 0 END)) END) END) / TGFITE.QTDNEG END) FROM TGFCAB CAB WHERE CAB.NUNOTA = TGFITE.NUNOTA) AS VLRUNITLIQ, ( SELECT (CASE WHEN TGFITE.QTDNEG = 0 THEN 0 ELSE (CASE WHEN CAB.TIPMOV IN('O','C','E') THEN TGFITE.VLRTOTMOE - TGFITE.VLRDESCMOE - TGFITE.VLRREPRED ELSE (CASE WHEN NVL((SELECT INTEIRO FROM TSIPAR WHERE CHAVE = 'TIPTABPRECO'),0) <> 9 THEN TGFITE.VLRTOTMOE - TGFITE.VLRDESCMOE - TGFITE.VLRREPRED ELSE (TGFITE.VLRTOTMOE - TGFITE.VLRDESCMOE - TGFITE.VLRREPRED) + TGFITE.VLRSUBST + ((CASE WHEN TGFITE.VLRIPI > 0 AND NVL((SELECT SOMARIPI FROM TGFTOP TP WHERE TP.CODTIPOPER = CAB.CODTIPOPER AND TP.DHALTER = CAB.DHTIPOPER),'N') <> 'N' THEN TGFITE.VLRIPI ELSE 0 END)) END) END) / TGFITE.QTDNEG END) FROM TGFCAB CAB WHERE CAB.NUNOTA = TGFITE.NUNOTA) AS VLRUNITLIQMOE FROM TGFITE /*SQL_92_JOINED_TABLES*/  WHERE (TGFITE.NUNOTA = ? AND TGFITE.SEQUENCIA = ?)
