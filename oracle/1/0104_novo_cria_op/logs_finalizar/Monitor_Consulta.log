service-name: OperacaoProducaoSP.finalizarInstanciaAtividades
uri: /mgeprod/service.sbr
*/
SELECT
ITE.NUNOTA,
ITE.SEQUENCIA, 
(ITE.QTDNEG - ITE.QTDENTREGUE) AS SALDO
FROM TGFITE ITE
INNER JOIN TGFCAB C ON(C.NUNOTA = ITE.NUNOTA)
INNER JOIN TGFTOP T ON(T.CODTIPOPER = C.CODTIPOPER AND T.DHALTER = C.DHTIPOPER)
WHERE
ITE.PENDENTE = 'S'
AND (ITE.QTDNEG - ITE.QTDENTREGUE) > 0
AND T.ATUALEST = 'R'
AND C.TIPMOV <> 'F'
AND ITE.NUNOTA IN(
   SELECT 
   DISTINCT R.NUNOTA
   FROM TPRROPE R
   INNER JOIN TPRIATV IATV ON(IATV.IDIATV = R.IDIATV)
   INNER JOIN TPROEST OEST ON(R.IDEFX = OEST.IDEFX AND R.SEQOPER = OEST.SEQOPER)
   WHERE 
   IATV.IDIPROC = ? 
   AND OEST.BAIXARESERVAEST = 'S'
)
ORDER BY 1
